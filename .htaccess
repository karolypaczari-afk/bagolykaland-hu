# ============================================
# BAGOLYKALAND.HU — Performance & Caching Rules
# ============================================

# --- Custom 404 page ---
ErrorDocument 404 /pages/404/index.html

# --- 301 Redirects: old WordPress URLs → new site ---
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Old blog posts were at root level, now under /blog/
  RewriteRule ^a-buntetes-mint-neveles-eszkoze/?$ /blog/a-buntetes-mint-neveles-eszkoze/ [R=301,L]
  RewriteRule ^figyelem-a-gyakorlas-a-tanulas-megutaltatasanak-egyik-legjobb-modja-lehet/?$ /blog/figyelem-a-gyakorlas-a-tanulas-megutaltatasanak-egyik-legjobb-modja-lehet/ [R=301,L]
  RewriteRule ^kire-utott-ez-a-gyerek/?$ /blog/kire-utott-ez-a-gyerek/ [R=301,L]
  RewriteRule ^szerinted-is-felesleges-divathobort-az-iskola-elokeszito/?$ /blog/szerinted-is-felesleges-divathobort-az-iskola-elokeszito/ [R=301,L]
  RewriteRule ^te-is-kikered-a-gyermeked-velemenyet/?$ /blog/te-is-kikered-a-gyermeked-velemenyet/ [R=301,L]
  RewriteRule ^te-is-nehezen-viseled-hogy-folyton-rohangal-es-az-agyon-ugral-a-gyermeked/?$ /blog/te-is-nehezen-viseled-hogy-folyton-rohangal-es-az-agyon-ugral-a-gyermeked/ [R=301,L]

  # Old duplicate page at root level
  RewriteRule ^iskola-elokeszito-foglalkozas/?$ /foglalkozasaink/iskola-elokeszito-foglalkozas/ [R=301,L]

  # WordPress taxonomy/archive pages → blog
  RewriteRule ^category/blog/?$ /blog/ [R=301,L]
  RewriteRule ^category/post/?$ /blog/ [R=301,L]
  RewriteRule ^category/(.*)$ /blog/ [R=301,L]
  RewriteRule ^tag/(.*)$ /blog/ [R=301,L]
  RewriteRule ^author/(.*)$ /rolunk/ [R=301,L]

  # WordPress artifacts
  RewriteRule ^wp-content/(.*)$ / [R=301,L]
  RewriteRule ^wp-admin/?$ / [R=301,L]
  RewriteRule ^wp-login\.php$ / [R=301,L]
  RewriteRule ^feed/?$ / [R=301,L]
  RewriteRule ^comments/feed/?$ / [R=301,L]
  RewriteRule ^xmlrpc\.php$ / [R=301,L]
</IfModule>

# --- 410 Gone: legacy WordPress & casino-spam URL deindexing ---
# Remnants from a compromised WP era (2023-2024). Returning 410 Gone
# is faster than 404 for Google to drop these from the index.
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Legacy WP query-string URLs (?p=, ?cat=, ?author=, ?feed=, ?paged=)
  RewriteCond %{QUERY_STRING} (^|&)(p|cat|author|feed|paged)=[^&]+ [NC]
  RewriteRule .* - [G,L]

  # Casino affiliate-brand slugs
  RewriteRule ^(admiral|gaminator|5gringos|20bet|7bit|buran|malina|betwinner|betfair)-.*$ - [G,L]

  # Gambling topic slugs (encoded + decoded Hungarian variants)
  RewriteRule ^.*casino.*$ - [G,L,NC]
  RewriteRule ^.*kaszin.*$ - [G,L,NC]
  RewriteRule ^.*baccarat.*$ - [G,L,NC]
  RewriteRule ^.*rulett.*$ - [G,L,NC]
  RewriteRule ^.*-rtp-.*$ - [G,L,NC]
  RewriteRule ^.*b%C3%B3nusz.*$ - [G,L,NC]
  RewriteRule ^.*bonusz.*$ - [G,L,NC]
  RewriteRule ^.*nyer%C5%91g.*$ - [G,L,NC]
  RewriteRule ^.*nyer[oő]g.*$ - [G,L,NC]
  RewriteRule ^.*p%C3%B3ker.*$ - [G,L,NC]
  RewriteRule ^.*-poker.*$ - [G,L,NC]
  RewriteRule ^poker-.*$ - [G,L,NC]
  RewriteRule ^%C3%A9l%C5%91-.*$ - [G,L,NC]
  RewriteRule ^%C3%BAj-(kaszin|online-baccarat|online-rulett|nyer|casino).*$ - [G,L,NC]
</IfModule>

# --- Clean URLs: /slug/ serves from /pages/slug/ ---
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Skip rewriting for real root-level resources
  RewriteCond %{REQUEST_URI} ^/(api|css|js|img|_data|_includes|manifest\.webmanifest|service-worker\.js|robots\.txt|sitemap\.xml|llms\.txt|llms-full\.txt|index\.html|favicon) [OR]
  RewriteCond %{REQUEST_URI} ^/pages/
  RewriteRule ^ - [L]

  # Rewrite /slug/ to /pages/slug/ if the file exists there
  RewriteCond %{DOCUMENT_ROOT}/pages%{REQUEST_URI}index.html -f
  RewriteRule ^(.*)$ /pages/$1 [L]

  # Also handle /slug (without trailing slash) → /pages/slug/
  RewriteCond %{DOCUMENT_ROOT}/pages%{REQUEST_URI}/index.html -f
  RewriteRule ^(.+[^/])$ /$1/ [R=301,L]
</IfModule>

# --- GZIP Compression ---
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE text/javascript
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE application/manifest+json
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE application/xml
  AddOutputFilterByType DEFLATE text/xml
</IfModule>

# --- Browser Caching ---
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML — short cache, visitors get fresh content quickly after deploy
  ExpiresByType text/html "access plus 5 minutes"

  # CSS & JS — long cache, busted by ?v= query string on each build
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType text/javascript "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"

  # Images — long cache, rarely change
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"

  # Fonts — long cache
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"
  ExpiresByType application/font-woff "access plus 1 year"

  # Manifest & JSON — medium cache
  ExpiresByType application/manifest+json "access plus 1 week"
  ExpiresByType application/json "access plus 1 hour"
</IfModule>

# --- Cache-Control Headers ---
<IfModule mod_headers.c>
  # HTML: must-revalidate so browsers check for updates
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "public, max-age=300, must-revalidate"
  </FilesMatch>

  # CSS & JS: immutable-like with long max-age (busted by ?v= query string)
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>

  # Images: long cache
  <FilesMatch "\.(webp|jpg|jpeg|png|gif|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Fonts: long cache
  <FilesMatch "\.(woff2|woff|ttf|otf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
    Header set Access-Control-Allow-Origin "*"
  </FilesMatch>

  # Webmanifest
  <FilesMatch "\.webmanifest$">
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>

  # Service worker must not be cached aggressively
  <FilesMatch "service-worker\.js$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
</IfModule>

# --- Security Headers ---
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=(self), payment=()"
  Header set X-XSS-Protection "1; mode=block"
</IfModule>

# --- Correct MIME Types ---
<IfModule mod_mime.c>
  AddType application/manifest+json .webmanifest
  AddType image/webp .webp
  AddType font/woff2 .woff2
</IfModule>
