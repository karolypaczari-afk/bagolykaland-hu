{
  "$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
  "files": {
    "includes": [
      "*.json",
      "playwright.config.js",
      "_dev/**/*.js",
      "!!.claude",
      "!!blob-report",
      "!!node_modules",
      "!!package-lock.json",
      "!!playwright-report",
      "!!test-results",
      "!!_dev/errors",
      "!!_dev/input",
      "!!_dev/photos"
    ],
    "ignoreUnknown": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 4,
    "lineEnding": "lf",
    "lineWidth": 120
  },
  "linter": {
    "enabled": false
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "es5",
      "semicolons": "always"
    }
  },
  "overrides": [
    {
      "includes": ["*.json"],
      "formatter": {
        "indentWidth": 2
      }
    }
  ]
}
