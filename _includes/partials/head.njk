  <!-- WebSite – sitelinks search box + global publisher reference -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": "https://bagolykaland.hu/#website",
    "url": "https://bagolykaland.hu/",
    "name": "BagolykaLand",
    "description": "BagolykaLand Oktató- és Fejlesztő Központ weboldala – fejlesztő foglalkozások, vizsgálatok és képzések Debrecenben.",
    "inLanguage": "hu-HU",
    "publisher": { "@id": "https://bagolykaland.hu/#organization" },
    "potentialAction": {
      "@type": "SearchAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": "https://bagolykaland.hu/?q={search_term_string}"
      },
      "query-input": "required name=search_term_string"
    }
  }
  </script>

  <!-- WebPage – speakable + breadcrumb (auto from front matter) -->
  {% set _pageName = ogTitle if ogTitle else title %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": "{{ canonical }}#webpage",
    "url": "{{ canonical }}",
    "name": {{ _pageName | dump | safe }},
    "description": {{ (ogDescription if ogDescription else description) | dump | safe }},
    "inLanguage": "hu-HU",
    "isPartOf": { "@id": "https://bagolykaland.hu/#website" },
    "about": { "@id": "https://bagolykaland.hu/#organization" },
    "primaryImageOfPage": {
      "@type": "ImageObject",
      "url": "{{ ogImage if ogImage else site.defaultOgImage }}"
    },
    {% if breadcrumbs %}
    "breadcrumb": { "@id": "{{ canonical }}#breadcrumb" },
    {% endif %}
    "speakable": {
      "@type": "SpeakableSpecification",
      "cssSelector": [".page-lead","h1",".lead",".tldr",".roviden"]
    },
    "potentialAction": {
      "@type": "ReadAction",
      "target": ["{{ canonical }}"]
    }
  }
  </script>

  {% if breadcrumbs %}
  <!-- BreadcrumbList (per-page from front matter) -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": "{{ canonical }}#breadcrumb",
    "itemListElement": [
      {% for crumb in breadcrumbs %}
      {
        "@type": "ListItem",
        "position": {{ loop.index }},
        "name": {{ crumb.name | dump | safe }}{% if crumb.url %},
        "item": "https://bagolykaland.hu{{ crumb.url }}"{% endif %}
      }{% if not loop.last %},{% endif %}
      {% endfor %}
    ]
  }
  </script>
  {% endif %}

  {% if serviceSchema %}
  <!-- Service schema (per-page) -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "{{ serviceSchema.type if serviceSchema.type else 'Service' }}",
    "@id": "{{ canonical }}#service",
    "name": {{ serviceSchema.name | dump | safe }},
    "description": {{ serviceSchema.description | dump | safe }},
    "serviceType": {{ serviceSchema.serviceType | dump | safe }},
    "category": {{ (serviceSchema.category if serviceSchema.category else "Gyermekfejlesztés") | dump | safe }},
    "provider": { "@id": "https://bagolykaland.hu/#organization" },
    "areaServed": [
      { "@type": "City", "name": "Debrecen" },
      { "@type": "AdministrativeArea", "name": "Hajdú-Bihar vármegye" }
    ],
    "audience": {
      "@type": "PeopleAudience",
      "suggestedMinAge": {{ serviceSchema.minAge if serviceSchema.minAge else 3 }},
      "suggestedMaxAge": {{ serviceSchema.maxAge if serviceSchema.maxAge else 12 }}
    },
    "url": "{{ canonical }}",
    "image": "{{ ogImage if ogImage else site.defaultOgImage }}"
    {% if serviceSchema.price %},
    "offers": {
      "@type": "Offer",
      "price": "{{ serviceSchema.price }}",
      "priceCurrency": "HUF",
      "availability": "https://schema.org/InStock",
      "url": "{{ canonical }}",
      "validFrom": "2026-01-01"
      {% if serviceSchema.duration %},
      "eligibleDuration": { "@type": "QuantitativeValue", "value": {{ serviceSchema.duration }}, "unitCode": "MIN" }
      {% endif %}
    }
    {% endif %}
    {% if serviceSchema.hasOfferCatalog %},
    "hasOfferCatalog": {{ serviceSchema.hasOfferCatalog | dump | safe }}
    {% endif %}
  }
  </script>
  {% endif %}

