  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>{{ title }}</title>
  <meta name="description" content="{{ description }}" />
  <meta name="robots" content="{{ robots if robots else 'index, follow' }}" />

  <!-- Open Graph -->
  <meta property="og:type"        content="website" />
  <meta property="og:url"         content="{{ canonical }}" />
  <meta property="og:title"       content="{{ ogTitle if ogTitle else title }}" />
  <meta property="og:description" content="{{ ogDescription if ogDescription else description }}" />
  <meta property="og:image"       content="{{ ogImage if ogImage else site.defaultOgImage }}" />
  <meta name="twitter:card"       content="summary_large_image" />
  <meta name="twitter:title"      content="{{ ogTitle if ogTitle else title }}" />
  <meta name="twitter:description" content="{{ ogDescription if ogDescription else description }}" />
  <meta name="twitter:image"      content="{{ ogImage if ogImage else site.defaultOgImage }}" />

  <!-- Canonical -->
  <link rel="canonical" href="{{ canonical }}" />

  <!-- App install -->
  <meta name="theme-color" content="#2B746D" />
  <meta name="application-name" content="BagolykaLand" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="default" />
  <meta name="apple-mobile-web-app-title" content="BagolykaLand" />
  <meta name="mobile-web-app-capable" content="yes" />
  <link rel="icon" type="image/png" sizes="32x32" href="/img/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/img/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/img/apple-touch-icon.png" />
  <link rel="manifest" href="/manifest.webmanifest" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@700;800;900&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet" />

  {% if preloadHero %}
  <link rel="preload" as="image" href="{{ preloadHero }}" type="image/webp" />
  {% endif %}

  <!-- Global Styles -->
  <link rel="stylesheet" href="/css/style.css{% if buildHash %}?v={{ buildHash }}{% endif %}" />

  {% if headStyles %}<style>{{ headStyles | safe }}</style>{% endif %}

  <!-- Structured Data – LocalBusiness -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "EducationalOrganization",
    "name": "BagolykaLand Oktató- és Fejlesztő Központ",
    "alternateName": "BagolykaLand",
    "url": "https://bagolykaland.hu",
    "logo": "https://bagolykaland.hu/img/logo.webp",
    "image": "https://bagolykaland.hu/img/bagolykaland-hero-group.webp",
    "description": "Gyermekfejlesztő központ Debrecenben 4–8 éves gyermekek számára. Logopédia, mozgásfejlesztés, egyéni fejlesztő foglalkozások és iskola-előkészítő képzett szakemberektől.",
    "telephone": "",
    "email": "",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Csokonai utca 32.",
      "addressLocality": "Debrecen",
      "postalCode": "4024",
      "addressCountry": "HU"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": "47.5308",
      "longitude": "21.6262"
    },
    "openingHoursSpecification": [
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
        "opens": "08:00",
        "closes": "18:00"
      }
    ],
    "founder": {
      "@type": "Person",
      "name": "Szabó-Varga Alexandra",
      "jobTitle": "Fejlesztőpedagógus, Alapozó Mozgásterapeuta"
    },
    "sameAs": [
      "https://zsenibagoly.hu"
    ],
    "areaServed": {
      "@type": "City",
      "name": "Debrecen"
    },
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Fejlesztő foglalkozások",
      "itemListElement": [
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Logopédia", "url": "https://bagolykaland.hu/foglalkozasaink/logopedia/" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Mozgásfejlesztés", "url": "https://bagolykaland.hu/foglalkozasaink/mozgasfejlesztes/" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Egyéni fejlesztő foglalkozások", "url": "https://bagolykaland.hu/foglalkozasaink/egyeni-fejleszto-foglalkozasok/" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Iskola-előkészítő", "url": "https://bagolykaland.hu/foglalkozasaink/iskola-elokeszito-foglalkozas/" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Szorongásoldó program", "url": "https://bagolykaland.hu/foglalkozasaink/szorongasoldo-program/" } }
      ]
    }
  }
  </script>
