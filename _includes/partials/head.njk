    "image": "{{ ogImage if ogImage else site.defaultOgImage }}",
    "audience": {
      "@type": "EducationalAudience",
      "educationalRole": "szülő, gyermek"
    },
    "teaches": {{ courseSchema.teaches | dump | safe }},
    "hasCourseInstance": {
      "@type": "CourseInstance",
      "courseMode": "{{ courseSchema.mode if courseSchema.mode else 'online' }}",
      "courseWorkload": "{{ courseSchema.workload if courseSchema.workload else 'PT4H' }}",
      "inLanguage": "hu"
      {% if courseSchema.price %},
      "offers": {
        "@type": "Offer",
        "price": "{{ courseSchema.price }}",
        "priceCurrency": "HUF",
        "category": "egyszeri díj",
        "availability": "https://schema.org/InStock",
        "url": "{{ courseSchema.offerUrl if courseSchema.offerUrl else canonical }}"
      }
      {% endif %}
    }
  }
  </script>
  {% endif %}

  {% if blogPost %}
  <!-- BlogPosting / Article schema (per-page) -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "@id": "{{ canonical }}#article",
    "mainEntityOfPage": { "@id": "{{ canonical }}#webpage" },
    "headline": {{ (blogPost.headline if blogPost.headline else title) | dump | safe }},
    "description": {{ (blogPost.description if blogPost.description else description) | dump | safe }},
    "image": ["{{ blogPost.image if blogPost.image else (ogImage if ogImage else site.defaultOgImage) }}"],
    "datePublished": "{{ blogPost.datePublished }}",
    "dateModified": "{{ blogPost.dateModified if blogPost.dateModified else blogPost.datePublished }}",
    "author": {
      "@type": "Person",
      "name": "{{ blogPost.author if blogPost.author else 'Szabó-Varga Alexandra' }}",
      "jobTitle": "Fejlesztőpedagógus",
      "worksFor": { "@id": "https://bagolykaland.hu/#organization" },
      "url": "https://bagolykaland.hu/rolunk/"
    },
    "publisher": { "@id": "https://bagolykaland.hu/#organization" },
    "inLanguage": "hu-HU",
    "isPartOf": { "@id": "https://bagolykaland.hu/#website" },
    "url": "{{ canonical }}",
    "wordCount": {{ blogPost.wordCount if blogPost.wordCount else 700 }},
    "articleSection": "{{ blogPost.section if blogPost.section else 'Szülőknek' }}",
    "keywords": {{ (blogPost.keywords if blogPost.keywords else ["gyermekfejlesztés","szülőknek","nevelés"]) | dump | safe }}
  }
  </script>
  {% endif %}

  {% if faq %}
  <!-- FAQPage schema (per-page) -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "@id": "{{ canonical }}#faq",
    "isPartOf": { "@id": "{{ canonical }}#webpage" },
    "mainEntity": [
      {% for item in faq %}
      {
        "@type": "Question",
        "name": {{ item.q | dump | safe }},
        "acceptedAnswer": {
          "@type": "Answer",
          "text": {{ item.a | dump | safe }}
        }
      }{% if not loop.last %},{% endif %}
      {% endfor %}
    ]
  }
  </script>
  {% endif %}
