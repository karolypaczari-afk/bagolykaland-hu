  {% if courseSchema %}
  <!-- Course schema (per-page) -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Course",
    "@id": "{{ canonical }}#course",
    "name": {{ courseSchema.name | dump | safe }},
    "description": {{ courseSchema.description | dump | safe }},
    "provider": { "@id": "https://bagolykaland.hu/#organization" },
    "educationalLevel": "{{ courseSchema.level if courseSchema.level else 'óvodás' }}",
    "educationalCredentialAwarded": "Részvételi igazolás",
