  <!-- Google Consent Mode v2 — granted by default (opt-out model).
       wait_for_update: lets late consent updates (banner click) arrive before tags fire.
       url_passthrough: preserves gclid/gbraid/wbraid across nav when cookies get blocked.
       ads_data_redaction: false since ad_storage is granted — keep full attribution. -->
  <script>
  window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}
  gtag('consent','default',{ad_storage:'granted',ad_user_data:'granted',ad_personalization:'granted',analytics_storage:'granted',wait_for_update:500});
  gtag('set','url_passthrough',true);
  gtag('set','ads_data_redaction',false);
  </script>

