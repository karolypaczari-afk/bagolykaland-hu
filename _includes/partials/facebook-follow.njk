{#
  Reusable Facebook follow card.
  Uses Meta's Page Plugin iframe (no SDK required, GDPR-safer than full SDK).
  The iframe is lazy-loaded so it doesn't block initial render.

  Optional variables (set with {% set %} before including):
    fbFollowEyebrow — small label above the title (default: "Közösség")
    fbFollowTitle   — main heading (default: "Kövess minket a Facebookon!")
    fbFollowLead    — supporting copy below the title
#}
<section class="section section-white fb-follow-section" aria-labelledby="fb-follow-heading">
  <div class="container">
    <div class="fb-follow fade-up">
      <div class="fb-follow__text">
        <span class="fb-follow__eyebrow">{{ fbFollowEyebrow or "Közösség" }}</span>
        <h2 id="fb-follow-heading" class="fb-follow__title">{{ fbFollowTitle or "Kövess minket a Facebookon!" }}</h2>
        <p class="fb-follow__lead">{{ fbFollowLead or "Friss hírek, fotók, tippek a gyermekneveléshez és bepillantás a mindennapjainkba — csatlakozz a BagolykaLand közösségéhez!" }}</p>
        <ul class="fb-follow__benefits">
          <li><span aria-hidden="true">✓</span> Szakmai tippek szülőknek hetente</li>
          <li><span aria-hidden="true">✓</span> Fotók és videók a foglalkozásokról</li>
          <li><span aria-hidden="true">✓</span> Események, akciók először nálunk</li>
        </ul>
        <a href="{{ site.social.facebook }}"
           target="_blank" rel="noopener noreferrer"
           class="btn btn-primary fb-follow__cta"
           data-track="bk_facebook_follow_click">
          <svg class="fb-follow__cta-icon" viewBox="0 0 24 24" fill="currentColor" width="18" height="18" aria-hidden="true"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
          Lájkold az oldalunkat
        </a>
      </div>
      <div class="fb-follow__widget">
        <iframe
          src="https://www.facebook.com/plugins/page.php?href=https%3A%2F%2Fwww.facebook.com%2Fbagolykaland&tabs=timeline&width=340&height=500&small_header=false&adapt_container_width=true&hide_cover=false&show_facepile=true"
          width="340" height="500"
          style="border:none;overflow:hidden;max-width:100%;"
          scrolling="no" frameborder="0" loading="lazy"
          allowfullscreen="true"
          allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share"
          title="BagolykaLand Facebook oldal">
        </iframe>
      </div>
    </div>
  </div>
</section>
