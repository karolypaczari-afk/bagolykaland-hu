{#
  Inline lead-catcher block — "5 ingyenes segédanyag" offer.
  Same MailerLite list as Zsenibagoly, tagged with source=bagolykaland.
#}
<section class="section section-white" aria-label="Feliratkozás">
  <div class="container">
    <div class="lead-catcher fade-up" data-lc-group="zsenifeszek" data-lc-source="bagolykaland">

      <span class="lead-catcher-emoji" aria-hidden="true">🦉</span>
      <span class="lead-catcher-tag">5 ingyenes segédanyag</span>
      <h3>Kapj 5 ingyenes szülői segédanyagot — fejlesztőpedagógustól, azonnal</h3>
      <p class="lead-catcher-desc">Iratkozz fel és küldünk <strong>5 gyakorlati anyagot</strong>, amit még ma kipróbálhatsz a gyerekeddel.</p>

      <ul class="lead-catcher-resources">
        <li><span class="lc-res-icon" aria-hidden="true">🔥</span><span class="lc-res-text"><strong>Top 5 tűzoltási technika</strong> — viselkedési krízishelyzetekre</span></li>
        <li><span class="lc-res-icon" aria-hidden="true">🎬</span><span class="lc-res-text"><strong>Hisztikezelés</strong> — 3 gyakorlati videó</span></li>
        <li><span class="lc-res-icon" aria-hidden="true">😰</span><span class="lc-res-text"><strong>Szorongásoldás</strong> — gyakorlati példa videóval</span></li>
        <li><span class="lc-res-icon" aria-hidden="true">📝</span><span class="lc-res-text"><strong>Figyelemfejlesztés</strong> — 3 Jolly Joker feladat (letölthető)</span></li>
        <li><span class="lc-res-icon" aria-hidden="true">🎓</span><span class="lc-res-text"><strong>Iskolaérettség</strong> — mik az elvárások?</span></li>
      </ul>

      <form class="lead-catcher-form" data-lc-form>
        <label for="lc-name" class="sr-only">Keresztnév</label>
        <input type="text" id="lc-name" name="name" placeholder="Keresztneved" required autocomplete="given-name" />
        <label for="lc-email" class="sr-only">E-mail cím</label>
        <input type="email" id="lc-email" name="email" placeholder="E-mail címed" required autocomplete="email" />
        <button type="submit">Kérem az 5 ingyenes segédanyagot!</button>
      </form>
      <p class="lead-catcher-gdpr">Csatlakozz több száz tudatos szülőhöz — teljesen ingyen! Bármikor leiratkozhatsz. <a href="/adatkezelesi-tajekoztato/" target="_blank" rel="noopener noreferrer">Adatkezelési tájékoztató</a></p>
      <div class="lead-catcher-success">
        <div class="lead-catcher-success-icon">✓</div>
        <h4>Köszönjük!</h4>
        <p>Hamarosan megérkeznek az e-mailben a segédanyagok!</p>
      </div>
    </div>
  </div>
</section>
