{#
  Inline lead-catcher block.
  Pass `leadContext` from the page front matter to pick the right magnet:
    szorongas | sulirajt | mozgas | logopedia | general (default)
#}
{% set ctx = leadContext | default("general") %}

{% set magnets = {
  "szorongas": {
    "tag": "Ingyenes utmutato",
    "title": "Segits a gyermekednek leküzdeni a szorongast!",
    "desc": "Kapd meg ingyenes utmutatonkat, amellyel konkret lepeseket tehetsz a szorongas oldasaert otthon is!",
    "button": "Kerem az utmutatot!",
    "group": "szorongas"
  },
  "sulirajt": {
    "tag": "Ingyenes checklist",
    "title": "Iskolaérett a gyermeked? Derítsd ki!",
    "desc": "Töltsd le ingyenes iskolaérettségi checklistünket és lépj magabiztosan az iskolakezdés felé!",
    "button": "Kérem a checklistet!",
    "group": "sulirajt"
  },
  "mozgas": {
    "tag": "Ingyenes tippek",
    "title": "3 mozgásfejleszto gyakorlat, amit otthon is végezhetsz!",
    "desc": "Iratkozz fel és küldünk 3 könnyen elvégezheto, otthoni mozgásfejleszto gyakorlatot!",
    "button": "Kérem a 3 tippet!",
    "group": "mozgas"
  },
  "logopedia": {
    "tag": "Ingyenes utmutato",
    "title": "Hogyan segitheted a gyermeked beszédfejlodését otthon?",
    "desc": "Küldjük el ingyenes utmutatonkat a mindennapos beszédfejlesztéshez!",
    "button": "Kérem az utmutatot!",
    "group": "logopedia"
  },
  "general": {
    "tag": "Ingyenes hirlevél",
    "title": "Szakértoi tippek a gyermeked fejlesztéséhez",
    "desc": "Csatlakozz hírlevelünkhöz és kapj hasznos tippeket, módszereket közvetlenül a Bagolykáktól!",
    "button": "Feliratkozom!",
    "group": "general"
  }
} %}

{% set lm = magnets[ctx] if magnets[ctx] else magnets["general"] %}

<section class="section section-white" aria-label="Feliratkozás">
  <div class="container">
    <div class="lead-catcher fade-up" data-lc-group="{{ lm.group }}">
      <span class="lead-catcher-emoji" aria-hidden="true">🦉</span>
      <span class="lead-catcher-tag">{{ lm.tag }}</span>
      <h3>{{ lm.title }}</h3>
      <p class="lead-catcher-desc">{{ lm.desc }}</p>
      <form class="lead-catcher-form" data-lc-form>
        <label for="lc-name-{{ ctx }}" class="sr-only">Keresztnév</label>
        <input type="text" id="lc-name-{{ ctx }}" name="name" placeholder="Keresztneved" required autocomplete="given-name" />
        <label for="lc-email-{{ ctx }}" class="sr-only">E-mail cím</label>
        <input type="email" id="lc-email-{{ ctx }}" name="email" placeholder="E-mail címed" required autocomplete="email" />
        <button type="submit">{{ lm.button }}</button>
      </form>
      <p class="lead-catcher-gdpr">A feliratkozással elfogadod az <a href="/adatkezelesi-tajekoztato/" target="_blank" rel="noopener noreferrer">adatkezelési tájékoztatót</a>. Nem küldünk spamet.</p>
      <div class="lead-catcher-success">
        <div class="lead-catcher-success-icon">✓</div>
        <h4>Köszönjük!</h4>
        <p>Hamarosan megérkezik az e-mailed!</p>
      </div>
    </div>
  </div>
</section>
