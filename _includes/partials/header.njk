<div class="site-announcement" role="status" aria-label="Költözési információ és elérhetőségek">
  <div class="container site-announcement__inner">
    <p><strong>Költözünk!</strong> 2026. május 1-től új címünk: <strong>Debrecen, Csokonai út 32.</strong></p>
    <div class="announcement-contacts">
      <a href="{{ site.contact.phoneHref }}">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 014.69 13a19.79 19.79 0 01-3.07-8.67A2 2 0 013.6 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        <span>{{ site.contact.phone }}</span>
      </a>
      <a href="mailto:{{ site.contact.email }}">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        <span>{{ site.contact.email }}</span>
      </a>
      <a href="{{ site.social.facebook }}" target="_blank" rel="noopener noreferrer">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
        <span>Facebook</span>
      </a>
    </div>
  </div>
</div>
<header class="site-header" id="site-header-el" role="banner">
  <div class="container">
    <div class="header-inner">
      <a href="/" class="site-logo" aria-label="BagolykaLand – Főoldal">
        <picture>
          <source srcset="/img/logo-transparent.webp" type="image/webp">
          <img src="/img/logo-transparent.png"
               alt="BagolykaLand Oktató- és Fejlesztő Központ" width="200" height="52"
               style="height:50px;width:auto;object-fit:contain;"
               onerror="this.style.display='none';this.parentElement.nextElementSibling.style.display='flex'">
        </picture>
        <span class="logo-text" style="display:none">
          <span class="logo-name">BAGOLYKALAND</span>
          <span class="logo-sub">Oktató- és Fejlesztő Központ</span>
        </span>
      </a>
      <nav class="main-nav" aria-label="Főmenü">
        <ul class="nav-list" role="list">
          {% for item in nav %}
            {% if item.children and item.megaType %}
              {# ─── MEGA MENU ITEM ─── #}
              <li class="nav-item nav-item--mega">
                <button class="nav-link" id="nav-mega-{{ loop.index }}" type="button" aria-expanded="false" aria-haspopup="true" aria-controls="nav-panel-{{ loop.index }}">{{ item.label }}<svg class="chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></button>

                {% if item.megaType == 'about' %}
                <div class="mega-panel mega-panel--compact mega-panel--about" id="nav-panel-{{ loop.index }}" role="region" aria-labelledby="nav-mega-{{ loop.index }}">
                  <div class="mega-panel__inner">
                    <div class="mega-nav">
                      {% for child in item.children %}
                        <a href="{{ child.url }}" class="mega-nav__link">
                          <span class="mega-nav__link-title">{{ child.label }}</span>
                          {% if child.desc %}<span class="mega-nav__link-desc">{{ child.desc }}</span>{% endif %}
                        </a>
                      {% endfor %}
                      {% if item.url %}<a href="{{ item.url }}" class="mega-nav__parent-link">Összes {{ item.label }} →</a>{% endif %}
                    </div>
                    <div class="mega-about-side">
                      {% if item.megaExtra.founderImg %}
                        <div class="mega-founder">
                          <img src="{{ item.megaExtra.founderImg }}" alt="{{ item.megaExtra.founderName }}" class="mega-founder__img" width="80" height="80" loading="lazy">
                          <div>
                            <span class="mega-founder__name">{{ item.megaExtra.founderName }}</span>
                            <span class="mega-founder__title">{{ item.megaExtra.founderTitle }}</span>
                          </div>
                        </div>
                      {% endif %}
                      {% if item.megaExtra.teamImg %}
                        <a href="{{ item.url }}" class="mega-team-link">
                          <img src="{{ item.megaExtra.teamImg }}" alt="{{ item.megaExtra.teamLabel }}" class="mega-team-link__img" width="320" height="180" loading="lazy">
                          <span>{{ item.megaExtra.teamLabel }}</span>
                        </a>
                      {% endif %}
                      <a href="{{ site.contact.phoneHref }}" class="mega-phone">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 014.69 13a19.79 19.79 0 01-3.07-8.67A2 2 0 013.6 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
                        {{ site.contact.phone }}
                      </a>
                    </div>
                  </div>
                </div>

                {% elif item.megaType == 'services' %}
                <div class="mega-panel mega-panel--full mega-panel--services" id="nav-panel-{{ loop.index }}" role="region" aria-labelledby="nav-mega-{{ loop.index }}">
                  <div class="mega-panel__inner">
                    <div class="mega-services mega-services--cols-{{ item.children | length }}">
                      {% for child in item.children %}
                        <a href="{{ child.url }}" class="mega-service-card">
                          {% if child.icon %}<img src="{{ child.icon }}" alt="" class="mega-service-card__icon" width="72" height="72" loading="lazy">{% endif %}
                          <span class="mega-service-card__title">{{ child.label }}</span>
                          {% if child.desc %}<span class="mega-service-card__desc">{{ child.desc }}</span>{% endif %}
                        </a>
                      {% endfor %}
                    </div>
                    <div class="mega-panel__footer">
                      {% if item.url %}<a href="{{ item.url }}" class="mega-nav__parent-link">Összes {{ item.label }} →</a>{% endif %}
                      <div class="mega-panel__footer-ctas">
                        {% if item.megaExtra.ctaLabel %}<a href="{{ item.megaExtra.ctaUrl }}" class="mega-cta mega-cta--primary">📅 {{ item.megaExtra.ctaLabel }}</a>{% endif %}
                        {% if item.megaExtra.ctaSecondaryLabel %}<a href="{{ item.megaExtra.ctaSecondaryUrl }}" class="mega-cta mega-cta--secondary">{{ item.megaExtra.ctaSecondaryLabel }}</a>{% endif %}
                      </div>
                    </div>
                  </div>
                </div>

                {% elif item.megaType == 'programs' %}
                <div class="mega-panel mega-panel--compact mega-panel--programs" id="nav-panel-{{ loop.index }}" role="region" aria-labelledby="nav-mega-{{ loop.index }}">
                  <div class="mega-panel__inner">
                    <div class="mega-services mega-services--cols-{{ item.children | length }}">
                      {% for child in item.children %}
                        <a href="{{ child.url }}" class="mega-service-card">
                          {% if child.icon %}<img src="{{ child.icon }}" alt="" class="mega-service-card__icon" width="72" height="72" loading="lazy">{% endif %}
                          <span class="mega-service-card__title">{{ child.label }}</span>
                          {% if child.desc %}<span class="mega-service-card__desc">{{ child.desc }}</span>{% endif %}
                          {% if child.badge %}<span class="mega-service-card__badge">{{ child.badge }}</span>{% endif %}
                        </a>
                      {% endfor %}
                    </div>
                    {% if item.megaExtra.ctaLabel %}
                    <div class="mega-panel__footer">
                      <a href="{{ item.megaExtra.ctaUrl }}" class="mega-cta mega-cta--primary">📅 {{ item.megaExtra.ctaLabel }}</a>
                    </div>
                    {% endif %}
                  </div>
                </div>

                {% elif item.megaType == 'knowledge' %}
                <div class="mega-panel mega-panel--full mega-panel--knowledge" id="nav-panel-{{ loop.index }}" role="region" aria-labelledby="nav-mega-{{ loop.index }}">
                  <div class="mega-panel__inner">
                    <div class="mega-nav">
                      {% for child in item.children %}
                        <a href="{{ child.url }}" class="mega-nav__link">
                          <span class="mega-nav__link-title">{{ child.label }}</span>
                          {% if child.desc %}<span class="mega-nav__link-desc">{{ child.desc }}</span>{% endif %}
                        </a>
                      {% endfor %}
                    </div>
                    {% if item.megaExtra.featuredPosts %}
                    <div class="mega-blog-section">
                      <p class="mega-blog-section__heading">Kiemelt cikkek</p>
                      <div class="mega-blog-grid">
                        {% for post in item.megaExtra.featuredPosts %}
                          <a href="{{ post.url }}" class="mega-blog-card">
                            <img src="{{ post.img }}" alt="" class="mega-blog-card__img" width="280" height="160" loading="lazy">
                            <span class="mega-blog-card__title">{{ post.title }}</span>
                          </a>
                        {% endfor %}
                      </div>
                      <a href="/blog/" class="mega-nav__parent-link">Összes cikk →</a>
                    </div>
                    {% endif %}
                  </div>
                </div>
                {% endif %}

              </li>

            {% elif item.children %}
              {# ─── SIMPLE DROPDOWN (fallback) ─── #}
              <li class="nav-item">
                <button class="nav-link" id="nav-dropdown-{{ loop.index }}" type="button" aria-expanded="false" aria-haspopup="true" aria-controls="nav-dropdown-panel-{{ loop.index }}">{{ item.label }}<svg class="chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></button>
                <div class="dropdown" id="nav-dropdown-panel-{{ loop.index }}" role="region" aria-labelledby="nav-dropdown-{{ loop.index }}">
                  {% if item.url %}<a href="{{ item.url }}" class="dropdown-parent-link">Összes {{ item.label }}</a>{% endif %}
                  {% for child in item.children %}
                    <a href="{{ child.url }}">{{ child.label }}</a>
                  {% endfor %}
                </div>
              </li>
            {% elif item.external %}
              <li class="nav-item"><a class="nav-link" href="{{ item.url }}" target="_blank" rel="noopener noreferrer">{{ item.label }}<svg class="icon-ext" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14" style="margin-left:4px;vertical-align:-1px;opacity:.6"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg></a></li>
            {% else %}
              <li class="nav-item"><a class="nav-link" href="{{ item.url }}">{{ item.label }}</a></li>
            {% endif %}
          {% endfor %}
        </ul>
        <a href="/kapcsolat/" class="nav-cta" aria-label="Időpontfoglalás">
          <span class="nav-cta__icon" aria-hidden="true">📅</span>
          <span class="nav-cta__label">Időpontfoglalás</span>
        </a>
      </nav>
      <div class="header-actions">
        <button class="nav-install js-install-app" type="button" hidden aria-haspopup="dialog" aria-label="BagolykaLand telepítése">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3v11"/><path d="m7 10 5 5 5-5"/><path d="M5 21h14"/></svg>
          <span class="nav-install-label">Telepítés</span>
        </button>
        <button class="hamburger" id="hamburger-btn" aria-label="Menü megnyitása" aria-expanded="false" aria-controls="mobile-nav">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
  </div>
</header>
<div class="mega-backdrop" id="mega-backdrop" aria-hidden="true"></div>
<nav class="mobile-nav" id="mobile-nav" aria-label="Mobil menü" aria-hidden="true">
  <ul class="mobile-nav-list" role="list">
    {% for item in nav %}
      {% if item.children %}
        <li class="mobile-nav-item">
          <button class="mobile-nav-link" id="mobile-nav-toggle-{{ loop.index }}" type="button" aria-expanded="false" aria-controls="mobile-dropdown-{{ loop.index }}">{{ item.label }}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></button>
          <div class="mobile-dropdown" id="mobile-dropdown-{{ loop.index }}" aria-labelledby="mobile-nav-toggle-{{ loop.index }}">
            {% if item.url %}<a href="{{ item.url }}" class="mobile-dropdown-parent-link">Összes {{ item.label }}</a>{% endif %}
            {% for child in item.children %}
              <a href="{{ child.url }}" class="mobile-dropdown__link">
                {% if child.icon %}<img src="{{ child.icon }}" alt="" class="mobile-dropdown__icon" width="24" height="24" loading="lazy">{% endif %}
                <span>{{ child.label }}</span>
                {% if child.badge %}<span class="mobile-dropdown__badge">{{ child.badge }}</span>{% endif %}
              </a>
            {% endfor %}
            {% if item.megaExtra and item.megaExtra.ctaLabel %}
              <a href="{{ item.megaExtra.ctaUrl }}" class="mobile-dropdown__cta">📅 {{ item.megaExtra.ctaLabel }}</a>
            {% endif %}
          </div>
        </li>
      {% elif item.external %}
        <li><a class="mobile-nav-link" href="{{ item.url }}" target="_blank" rel="noopener noreferrer">{{ item.label }}<svg class="icon-ext" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14" style="margin-left:4px;vertical-align:-1px;opacity:.6"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg></a></li>
      {% else %}
        <li><a class="mobile-nav-link" href="{{ item.url }}">{{ item.label }}</a></li>
      {% endif %}
    {% endfor %}
  </ul>
  <a href="/kapcsolat/" class="mobile-cta">📅 Időpontfoglalás</a>
</nav>
