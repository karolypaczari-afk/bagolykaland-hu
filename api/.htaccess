# Block public access to logs directory
RedirectMatch 403 ^/api/logs(/.*)?$

# Block direct access to any .log file
<FilesMatch "\.log$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
  </IfModule>
</FilesMatch>

# Block access to config files
<FilesMatch "^(smtp-config|admin-config|capi-config)(\.example)?\.php$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
  </IfModule>
</FilesMatch>
