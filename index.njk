                    <span>Google vélemény</span>
                  </div>
                </div>
                <div class="review-card__stars" role="img" aria-label="{{ review.rating }} csillag">★★★★★</div>
              </div>
              <p class="review-card__text">"{{ review.text }}"</p>
            </article>
            {% endfor %}
