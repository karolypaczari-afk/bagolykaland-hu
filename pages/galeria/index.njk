        text-align: center;
        margin-top: 2.5rem;
        padding: 1.5rem;
        background: #f0f7f2;
        border-radius: 12px;
        font-size: 1rem;
        color: #4a5568;
      }
      .gallery-note a {
        color: var(--clr-coral);
        font-weight: 600;
        text-decoration: none;
      }
      .gallery-note a:hover {
        text-decoration: underline;
