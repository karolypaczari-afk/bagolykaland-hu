    {# UX scripts: scroll-FAB + lightbox controller (JS-alapú, hogy a bezárás megbízhatóan működjön) #}
    <script>
      (function() {
        /* ───── FAB visibility on scroll ───── */
        var fabThreshold = 480;
        var ticking = false;
        function checkScroll() {
          ticking = false;
          document.body.classList.toggle('iek-scrolled', window.scrollY > fabThreshold);
        }
        window.addEventListener('scroll', function() {
          if (!ticking) { requestAnimationFrame(checkScroll); ticking = true; }
        }, { passive: true });
        checkScroll();

        /* ───── Lightbox controller ─────
           Cél: bezárás-kattintásra is megbízhatóan zárjon (a :target-et a
           globális smooth-scroll handler hosszan túllépte; ez egyszerűbb). */
        var lightboxes = document.querySelectorAll('.iek-lightbox');
        if (!lightboxes.length) return;

        function closeAll() {
          lightboxes.forEach(function(lb) { lb.classList.remove('is-open'); });
          document.body.classList.remove('iek-lb-active');
        }
        function openById(id) {
          closeAll();
          var lb = document.getElementById(id);
          if (lb) {
            lb.classList.add('is-open');
            document.body.classList.add('iek-lb-active');
          }
        }

        /* Capture-phase document click handler so we run BEFORE the global
           smooth-scroll handler (which intercepts a[href^="#"]).
           - Thumbnail click → open matching lightbox
           - Close button / backdrop click → close
           - Prev/Next click → switch lightbox */
        document.addEventListener('click', function(e) {
          var thumb = e.target.closest('.iek-gallery__item[href^="#iek-lb-"]');
          if (thumb) {
            e.preventDefault();
            e.stopImmediatePropagation();
            openById(thumb.getAttribute('href').slice(1));
            return;
          }
          var closeEl = e.target.closest('.iek-lightbox__close, .iek-lightbox__backdrop');
          if (closeEl) {
            e.preventDefault();
            e.stopImmediatePropagation();
            closeAll();
            return;
          }
          var navEl = e.target.closest('.iek-lightbox__nav a[href^="#iek-lb-"]');
          if (navEl) {
            e.preventDefault();
            e.stopImmediatePropagation();
            openById(navEl.getAttribute('href').slice(1));
            return;
          }
        }, true);

        /* ESC bezárja */
        document.addEventListener('keydown', function(e) {
          if (e.key === 'Escape' && document.body.classList.contains('iek-lb-active')) {
            closeAll();
          }
        });

        /* Mély-link támogatás: ha az URL #iek-lb-N-vel érkezik, nyisd meg */
        if (location.hash && location.hash.indexOf('#iek-lb-') === 0) {
          openById(location.hash.slice(1));
        }
      })();
    </script>
