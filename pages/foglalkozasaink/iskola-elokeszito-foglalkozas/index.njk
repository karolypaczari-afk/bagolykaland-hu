    }
    @media (min-width: 600px) {
      .iek-signs-list { grid-template-columns: 1fr 1fr; }
    }
    .iek-signs-list li {
      padding-left: 1.6rem;
      position: relative;
      font-size: 0.96rem;
      line-height: 1.55;
      color: var(--clr-text);
    }
    .iek-signs-list li::before {
      content: '×';
      position: absolute;
      left: 0;
      top: -0.05rem;
      color: var(--clr-coral);
