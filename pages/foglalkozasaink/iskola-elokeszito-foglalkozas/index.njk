    .iek-founder__photo { border-radius: 50%; overflow: hidden; aspect-ratio: 1; }
    .iek-founder__photo img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .iek-founder__body h3 { margin: 0 0 0.35rem; color: var(--clr-navy); }
    .iek-founder__role { color: var(--clr-teal); font-weight: 700; font-size: 0.92rem; margin: 0 0 0.65rem; }
    .iek-founder__body p { font-size: 0.96rem; line-height: 1.6; color: var(--clr-text); margin: 0; }
    @media (max-width: 600px) {
      .iek-founder { grid-template-columns: 1fr; text-align: center; }
      .iek-founder__photo { max-width: 160px; margin: 0 auto; }
    }

    /* ── GALÉRIA OVERRIDE ── */
    .iek-gallery { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 0.75rem; }
    .iek-gallery a { display: block; border-radius: var(--r-md); overflow: hidden; aspect-ratio: 4 / 3; }
    .iek-gallery img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform var(--t-mid); }
    .iek-gallery a:hover img { transform: scale(1.05); }

    /* ── CLOSING CTA ── */
    .iek-closing { background: linear-gradient(160deg, var(--clr-navy-deep) 0%, var(--clr-navy) 100%); color: #fff; text-align: center; padding: 4rem 0; }
    .iek-closing h2 { color: #fff; font-size: clamp(1.7rem, 3.5vw, 2.4rem); margin-bottom: 1.25rem; }
    .iek-closing p { color: rgba(255,255,255,0.9); font-size: 1.05rem; line-height: 1.65; max-width: 640px; margin: 0 auto 1rem; }
    .iek-closing__goals { list-style: none; padding: 0; max-width: 480px; margin: 1.5rem auto 2rem; display: flex; flex-direction: column; gap: 0.5rem; text-align: left; }
    .iek-closing__goals li { color: rgba(255,255,255,0.92); padding-left: 1.75rem; position: relative; font-size: 1rem; }
    .iek-closing__goals li::before { content: '✓'; position: absolute; left: 0; color: var(--clr-yellow); font-weight: 800; }

    /* ── FAQ (kept from style.src.css base, overrides for this page) ── */
    .faq-grid { display: flex; flex-direction: column; gap: 0.75rem; max-width: 820px; margin: 0 auto; }
    .faq-card { background: #fff; border: 1.5px solid #eef2f7; border-radius: var(--r-md); padding: 1rem 1.25rem; transition: border-color var(--t-fast); }
    .faq-card[open] { border-color: var(--clr-teal-light); box-shadow: var(--sh-sm); }
    .faq-card summary { cursor: pointer; font-weight: 700; color: var(--clr-navy); display: flex; align-items: center; gap: 0.75rem; list-style: none; }
    .faq-card summary::-webkit-details-marker { display: none; }
    .faq-card summary .faq-toggle { margin-left: auto; width: 28px; height: 28px; border-radius: 50%; background: var(--clr-bg); display: flex; align-items: center; justify-content: center; font-size: 1.15rem; font-weight: 800; color: var(--clr-teal); transition: transform var(--t-mid), background var(--t-fast); }
    .faq-card[open] summary .faq-toggle { transform: rotate(45deg); background: var(--clr-teal-light); }
    .faq-answer { font-size: 0.96rem; line-height: 1.65; color: var(--clr-text); padding: 0.85rem 0 0.25rem; }
    .faq-answer strong { color: var(--clr-navy); }
    .faq-answer a { color: var(--clr-teal); font-weight: 700; }
---


    {# ── 1. HERO — KÉPSZÖVEG (background image + emotion-focused copy) ── #}
    <section class="iek-hero" aria-labelledby="iek-hero-h">
      <div class="iek-hero__bg">
        <img src="/img/bagolykaland-iskola-elokeszito-jatekos-csoport.webp"
             alt=""
             width="1200" height="800"
             fetchpriority="high" />
      </div>
      <div class="container">
        <div class="iek-hero__inner">
          <nav class="breadcrumb fade-up" style="justify-content:center;">
            <a href="/" style="color:rgba(255,255,255,0.8);">Főoldal</a>
            <span style="color:rgba(255,255,255,0.6);">/</span>
            <a href="/foglalkozasaink/" style="color:rgba(255,255,255,0.8);">Foglalkozásaink</a>
            <span style="color:rgba(255,255,255,0.6);">/</span>
            <span style="color:#fff;">Iskola-előkészítő</span>
          </nav>

          <h1 id="iek-hero-h" class="fade-up stagger-1">Magabiztosabb, nyugodtabb iskolakezdés &mdash; <strong>kudarcélmények nélkül</strong></h1>
          <div class="accent-bar" style="background:var(--clr-yellow);margin:0 auto 1.25rem;"></div>

          <p class="iek-hero__sub fade-up stagger-2">
            A BagolykaLand iskola-előkészítő programja <strong>játékosan, fokozatosan</strong> készíti fel a gyermekedet az első osztályra, hogy szeptemberben ne szorongással, hanem önbizalommal induljon el az iskolába.
          </p>

          <p class="iek-hero__sub fade-up stagger-2" style="margin-top:1.25rem;">Sok szülő attól fél, hogy a gyermeke nehezen veszi majd az első osztály akadályait:</p>

          <ul class="iek-hero__fears fade-up stagger-2">
            <li>Nem tud hosszabban figyelni</li>
            <li>Könnyen feladja a feladatokat</li>
            <li>Szorong új helyzetekben</li>
            <li>Nem szeret asztalnál dolgozni</li>
            <li>Vagy egyszerűen még éretlennek tűnik az iskolához</li>
          </ul>

          <p class="iek-hero__close fade-up stagger-3">
            Mi pontosan ezekre a helyzetekre építettük fel a programunkat. <strong>Nem ültetjük a gyerekeket azonnal feladatlapokat tölteni</strong> &mdash; fokozatosan vezetjük át őket az óvodai működésből az iskolai helyzetek felé. Játékosan, mozgással, sikerélményekkel és egyéni figyelemmel.
          </p>

          <a href="#jelentkezes" class="btn btn-primary fade-up stagger-3">Jelentkezem iskolaelőkészítőre →</a>
        </div>
      </div>
    </section>


    {# ── 2. SZÜLŐI FÉLELMEK — egyoszlopos ── #}
    <section class="section section-white" aria-labelledby="iek-fears">
      <div class="container" style="max-width:760px;">
        <div class="section-header" style="text-align:center;">
          <span class="section-eyebrow fade-up">Talán Te is így vagy ezzel</span>
          <h2 id="iek-fears" class="fade-up stagger-1">„Mi lesz, ha nehezen indul az iskola?"</h2>
          <p class="fade-up stagger-2" style="max-width:660px;margin:0 auto;">Az iskolakezdés sok családban nem örömteli várakozás, hanem egy folyamatos belső aggodalom.</p>
        </div>

        <ul class="content-list fade-up" style="max-width:600px;margin:0 auto 1.75rem;">
          <li>„Vajon tud majd figyelni?"</li>
          <li>„Mi lesz, ha nem meri megmutatni, mit tud?"</li>
          <li>„Mi lesz, ha kudarcélmények érik?"</li>
          <li>„Mi lesz, ha nem tud beilleszkedni?"</li>
          <li>„Mi lesz, ha túl hamar elmegy a kedve az egésztől?"</li>
        </ul>

        <p class="fade-up" style="font-size:1.02rem;line-height:1.7;color:var(--clr-text);">
          Sok szülő azért keres meg minket, mert <strong>már látta ezt korábban egy nagyobb testvérnél</strong>. Látta, milyen gyorsan eltűnhet egy gyerek lelkesedése, amikor az első kudarcélmények megjelennek. Amikor a folyamatos javítás, siettetés vagy szorongás miatt az iskola stresszforrássá válik.
        </p>

        <p class="fade-up" style="font-size:1.02rem;line-height:1.7;color:var(--clr-text);">
          Mások egyszerűen csak <strong>szeretnék megelőzni ezt</strong>. Nem azért hozzák iskola-előkészítőre a gyermeküket, mert „baj van", hanem azért, mert szeretnék, hogy magabiztosabban induljon el az első osztályban. És ez teljesen érthető.
        </p>

        <div class="highlight-box fade-up" style="margin-top:1.5rem;">
          <p style="margin:0;font-size:1.02rem;">Az iskolaérettség <strong>nem csak arról szól</strong>, hogy felismeri-e a számokat vagy szépen fogja-e a ceruzát. Legalább ennyire fontos: <strong>tud-e figyelni, hogyan kezeli a kudarcot, képes-e feladathelyzetben maradni, mennyire önálló, hogyan működik közösségben, mer-e megszólalni és segítséget kérni.</strong></p>
          <p style="margin:0.85rem 0 0;font-size:1rem;color:var(--clr-text-mid);">A jó iskolakezdés alapja az, hogy a gyerek <strong>biztonságban érezze magát</strong> az új helyzetben.</p>
        </div>
      </div>
    </section>


    {# ── 3. MIÉRT NEM MŰKÖDIK — osztott (bad vs good) ── #}
    <section class="section section-cream" aria-labelledby="iek-why">
      <div class="container">
        <div class="section-header">
          <span class="section-eyebrow fade-up">Edukáció</span>
          <h2 id="iek-why" class="fade-up stagger-1">A legtöbb gyereknek idő kell az átálláshoz</h2>
          <p class="fade-up stagger-2" style="max-width:680px;margin:0 auto;">Miért nem működik sok gyereknél az azonnali „asztalhoz ültetés"?</p>
        </div>

        <div class="iek-compare fade-up">
          <article class="iek-compare__card iek-compare__card--bad">
            <h3>Sok helyen ez történik</h3>
            <p style="margin:0;font-size:0.95rem;color:var(--clr-text-mid);">A gyerekeket szinte azonnal iskolás helyzetbe teszik: asztal, feladatlap, ceruza, hosszabb figyelmi helyzetek. Csakhogy sok nagycsoportos óvodás még nincs erre felkészülve. Ilyenkor megjelenhet:</p>
            <ul>
              <li>Ellenállás, elutasítás</li>
              <li>Szorongás, könnyezés</li>
              <li>Unatkozás, fészkelődés</li>
              <li>Viselkedési problémák</li>
              <li>Gyors kifáradás, motivációvesztés</li>
              <li>Kudarcélmény: „pedig okos a gyerek…"</li>
            </ul>
          </article>

          <article class="iek-compare__card iek-compare__card--good">
            <h3>Mi ezért fokozatosan építjük fel</h3>
            <p style="margin:0;font-size:0.95rem;color:var(--clr-text-mid);">A foglalkozások elején sok játékos, mozgásos és fejlesztő helyzettel dolgozunk. A gyerekek először szőnyegen, kötetlenebb formában kapcsolódnak be a feladatokba, és csak később jutnak el az asztal melletti munkáig.</p>
            <ul>
              <li>Kisebb szorongás, biztonságérzet</li>
              <li>Könnyebb sikerélményhez jutni</li>
              <li>Tovább megmarad a motiváció</li>
              <li>Természetesebbé válik a feladathelyzet</li>
              <li>Stabilabb alapokra épül az iskolai működés</li>
              <li>Megőrzi a kíváncsiságát</li>
            </ul>
          </article>
        </div>

        <p class="fade-up" style="text-align:center;margin-top:2rem;max-width:680px;margin-left:auto;margin-right:auto;font-size:1.02rem;line-height:1.65;color:var(--clr-text);"><strong>A célunk nem az, hogy minél hamarabb „iskolásan viselkedjenek".</strong> A cél az, hogy biztonságosan és jó élményekkel érkezzenek meg az iskolába.</p>
      </div>
    </section>


    {# ── 4. HOGYAN MŰKÖDIK — képszöveg + 3 pillér ── #}
    <section class="section section-white" aria-labelledby="iek-how">
      <div class="container">
        <div class="section-header">
          <span class="section-eyebrow fade-up">A program</span>
          <h2 id="iek-how" class="fade-up stagger-1">Nem csak tanítjuk őket — fel is készítjük az iskolai helyzetekre</h2>
        </div>

        <div class="iek-imgtext fade-up">
          <div class="iek-imgtext__img">
            <img src="/img/bagolykaland-iskola-elokeszito-tantargyi-alapok.webp"
                 alt="Iskola-előkészítő foglalkozás közben, fejlesztő pedagógus és gyermek interakcióban — BagolykaLand"
                 width="800" height="600" loading="lazy" />
          </div>
          <div class="iek-imgtext__body">
            <p>A programot <strong>több mint 15 év szakmai tapasztalat</strong> alapján alakítottuk ki. <strong>Szabó-Varga Alexandra</strong> fejlesztő pedagógus minden évben folyamatosan frissíti a foglalkozások felépítését a gyerekek aktuális igényei és a tapasztalatok alapján.</p>
            <p>A cél nem a túlterhelés. <strong>A cél az, hogy a gyermeked magabiztosabban, nyugodtabban és felkészültebben kezdhesse meg az iskolát.</strong></p>
            <p style="margin-top:1.25rem;"><a href="#jelentkezes" class="btn btn-teal">Szeretnék érdeklődni a programról →</a></p>
          </div>
        </div>

        <div class="iek-pillars">
          <div class="iek-pillar fade-up" style="--pillar-c: var(--clr-teal);">
            <span class="iek-pillar__num">1</span>
            <h3>Részképesség-fejlesztés</h3>
            <p>A figyelem, emlékezet, koncentráció, finommotorika és az egyéb alap készségek fejlesztése játékos feladatokon keresztül.</p>
          </div>
          <div class="iek-pillar fade-up stagger-1" style="--pillar-c: var(--clr-coral);">
            <span class="iek-pillar__num">2</span>
            <h3>Fokozatos átmenet</h3>
            <p>A gyerekeket lépésről lépésre vezetjük át az óvodai működésből az iskolai feladathelyzetek felé — szőnyegtől az asztalig.</p>
          </div>
          <div class="iek-pillar fade-up stagger-2" style="--pillar-c: var(--clr-yellow);">
            <span class="iek-pillar__num">3</span>
            <h3>Pozitív élmények és motiváció</h3>
            <p>Fontos számunkra, hogy a gyerekek szeressenek hozzánk járni. Hosszú távon az tud igazán fejlődni, aki biztonságban van és sikerélményt szerez.</p>
          </div>
        </div>
      </div>
    </section>


    {# ── 5. MIT FEJLESZT — 6 kártya ── #}
    <section class="section section-cream" aria-labelledby="iek-skills">
      <div class="container">
        <div class="section-header">
          <span class="section-eyebrow fade-up">Mit fejleszt</span>
          <h2 id="iek-skills" class="fade-up stagger-1">Azokat a készségeket fejlesztjük, amelyekre az iskolában valóban szükség lesz</h2>
        </div>

        <div class="services-grid">
          <article class="service-card fade-up" style="--accent: var(--clr-sky);">
            <div class="service-card-top"></div>
            <div class="service-card-body">
              <h3>Figyelem és koncentráció</h3>
              <p>Hogy hosszabb ideig is képes legyen feladathelyzetben maradni — ne 5 perc után kalandozzon el.</p>
            </div>
          </article>

          <article class="service-card fade-up stagger-1" style="--accent: var(--clr-coral);">
            <div class="service-card-top"></div>
            <div class="service-card-body">
              <h3>Finommotorika</h3>
              <p>Hogy könnyebbé váljon az írás, rajzolás és ceruzahasználat. Görcsmentesen, lendülettel.</p>
            </div>
          </article>

          <article class="service-card fade-up stagger-2" style="--accent: var(--clr-purple);">
            <div class="service-card-top"></div>
            <div class="service-card-body">
              <h3>Emlékezet</h3>
              <p>Hogy könnyebben tudjon új információkat megjegyezni és alkalmazni a tanulási helyzetekben.</p>
            </div>
          </article>

          <article class="service-card fade-up stagger-3" style="--accent: var(--clr-yellow);">
            <div class="service-card-top"></div>
            <div class="service-card-body">
              <h3>Feladattudat</h3>
              <p>Hogy ne adja fel azonnal, ha valami elsőre nehezebben megy — kitartson a feladat mellett.</p>
            </div>
          </article>

          <article class="service-card fade-up stagger-4" style="--accent: var(--clr-green);">
            <div class="service-card-top"></div>
            <div class="service-card-body">
              <h3>Szociális készségek</h3>
              <p>Hogy bátrabban kommunikáljon és könnyebben kapcsolódjon másokhoz — pedagógussal és társakkal egyaránt.</p>
            </div>
          </article>

          <article class="service-card fade-up stagger-5" style="--accent: var(--clr-pink);">
            <div class="service-card-top"></div>
            <div class="service-card-body">
              <h3>Kudarctűrés és önbizalom</h3>
              <p>Hogy a hibák ne elvegyék a kedvét, hanem tanulási helyzetekké váljanak. „Megpróbálom újra" gondolkodás.</p>
            </div>
          </article>
        </div>
      </div>
    </section>


    {# ── 6. FOKOZATOS ÁTMENET — egyoszlopos ── #}
    <section class="section section-white" aria-labelledby="iek-transition">
      <div class="container" style="max-width:760px;text-align:center;">
        <div class="section-header">
          <span class="section-eyebrow fade-up">Differenciátor</span>
          <h2 id="iek-transition" class="fade-up stagger-1">Nem kisiskolásokat akarunk csinálni az óvodásokból</h2>
        </div>

        <p class="lead fade-up" style="text-align:center;">Sokkal fontosabbnak tartjuk, hogy a gyerekek <strong>fokozatosan érkezzenek meg</strong> az iskolai működésbe.</p>

        <p class="fade-up" style="font-size:1.02rem;line-height:1.7;color:var(--clr-text);">A túl gyors átállás sok gyereknél szorongást, ellenállást, túlterheltséget és motivációvesztést okozhat.</p>

        <p class="fade-up" style="font-size:1.02rem;line-height:1.7;color:var(--clr-text);">Mi ezért úgy építjük fel a foglalkozásokat, hogy közben a gyerekek <strong>megőrizzék a kíváncsiságukat</strong> és a természetes motivációjukat.</p>

        <div class="highlight-box fade-up" style="margin-top:1.75rem;">
          <p style="margin:0;font-size:1.05rem;"><strong>A játékosság nálunk nem „jutalom" — hanem a tanulási folyamat része.</strong></p>
          <p style="margin:0.75rem 0 0;color:var(--clr-text-mid);">Így a gyerekek nem kényszerként élik meg a feladatokat, hanem biztonságos, sikerélményekkel teli helyzetként.</p>
        </div>
      </div>
    </section>


    {# ── 7. BEMENETI ÉS KIMENETI MÉRÉS — osztott ── #}
    <section class="section section-cream" aria-labelledby="iek-measure">
      <div class="container">
        <div class="section-header">
          <span class="section-eyebrow fade-up">Bizalomépítés</span>
          <h2 id="iek-measure" class="fade-up stagger-1">Nem csak fejlesztünk — pontos képet is adunk a gyermeked fejlődéséről</h2>
          <p class="fade-up stagger-2" style="max-width:680px;margin:0 auto;">Bemeneti és kimeneti méréssel követjük a fejlődést. A változás nem csak érzésre látható — mérhető is.</p>
        </div>

        <div class="iek-meres fade-up">
          <article class="iek-meres__card iek-meres__card--in">
            <span class="iek-meres__eyebrow">Program elején</span>
            <h3>Bemeneti mérés</h3>
            <ul>
              <li>A gyermek aktuális készségszintje</li>
              <li>Az erősségei</li>
              <li>Azok a területek, ahol még támogatásra van szüksége</li>
              <li>Egyéni fejlesztési irányok</li>
            </ul>
          </article>

          <article class="iek-meres__card iek-meres__card--out">
            <span class="iek-meres__eyebrow">Program végén</span>
            <h3>Kimeneti mérés + írásos elemzés</h3>
            <ul>
              <li>Miben fejlődött a gyermeked</li>
              <li>Mely területek erősödtek meg</li>
              <li>Mire érdemes még figyelni az iskolakezdés előtt</li>
              <li>Részletes írásos elemzés a szülőnek</li>
            </ul>
          </article>
        </div>
      </div>
    </section>


    {# ── 8. KISCSOPORTOS MŰKÖDÉS — képszöveg ── #}
    <section class="section section-white" aria-labelledby="iek-group">
      <div class="container">
        <div class="section-header">
          <span class="section-eyebrow fade-up">Kiscsoportos figyelem</span>
          <h2 id="iek-group" class="fade-up stagger-1">Minden gyermekre jut idő és figyelem</h2>
        </div>

        <div class="iek-imgtext iek-imgtext--reverse fade-up">
          <div class="iek-imgtext__img">
            <img src="/img/bagolykaland-iskola-elokeszito-csoport-kor-2025.webp"
                 alt="Iskola-előkészítő kiscsoport körben, koncentrált foglalkozás — BagolykaLand"
                 width="800" height="600" loading="lazy" />
          </div>
          <div class="iek-imgtext__body">
            <p>A kiscsoportos működés egyik legnagyobb előnye, hogy a pedagógusok <strong>valóban megismerik a gyerekeket</strong>. Látják, hogyan reagálnak a feladatokra, mi motiválja őket, hol bizonytalanodnak el, mely területeken fejlődnek gyorsabban.</p>
            <p><strong>Maximum 8–10 fős csoportokban dolgozunk</strong> — pont annyi, hogy működjön a társas dinamika, de minden gyermek teljes körű figyelmet kapjon.</p>
            <p>A szülők minden foglalkozás után visszajelzést kapnak. Szükség esetén átbeszéljük az esetleges nehézségeket, a fejlődési irányokat és az otthoni támogatás lehetőségeit.</p>
            <p style="font-size:0.95rem;color:var(--clr-text-mid);">Mivel a BagolykaLandban többféle fejlesztő foglalkozás is elérhető, szükség esetén további szakmai segítséget is tudunk javasolni — így a gyermek egy <strong>komplexebb támogatási rendszerben</strong> fejlődhet.</p>
          </div>
        </div>
      </div>
    </section>


