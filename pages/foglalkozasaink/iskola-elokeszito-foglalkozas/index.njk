    .iek-form-card--teal  { --iek-form-accent: var(--clr-teal); }
    .iek-form-card h3 { color: var(--clr-navy); margin: 0 0 0.4rem; font-size: 1.15rem; }
    .iek-form-card__sub { font-size: 0.88rem; color: var(--clr-text-mid); line-height: 1.55; margin: 0 0 1.1rem; }
    .iek-form-card__sub strong { color: var(--clr-navy); }
    .iek-form-card form { display: flex; flex-direction: column; gap: 0.65rem; }
