      top: 0; left: 0; right: 0;
      height: 5px;
      background: var(--iek-stack-accent, var(--clr-teal));
    }
    .moz-value-stack--coral { --iek-stack-accent: var(--clr-coral); }
    .moz-value-stack--teal { --iek-stack-accent: var(--clr-teal); }
    .moz-value-stack__head {
      margin-bottom: 0.5rem;
    }
    .moz-value-stack__head .iek-stack-eyebrow {
      font-size: 0.72rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--iek-stack-accent, var(--clr-teal));
    }
    .moz-value-stack__head h3 {
      color: var(--clr-navy);
      font-size: 1.15rem;
      margin: 0.2rem 0 0.5rem;
    }
    .moz-value-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.65rem 0;
      border-bottom: 1px dashed rgba(29,53,87,0.12);
      gap: 1rem;
    }
    .moz-value-label { font-size: 0.9rem; color: var(--clr-text); flex: 1; padding-right: 0.5rem; line-height: 1.45; }
    .moz-value-price { font-size: 0.88rem; color: var(--clr-text-muted); font-weight: 600; white-space: nowrap; }
    .moz-value-total {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1rem 0 0.65rem;
      border-top: 2px solid var(--clr-navy);
      margin-top: 0.25rem;
    }
    .moz-value-total-label { font-weight: 800; font-size: 1rem; color: var(--clr-navy); }
    .moz-value-total-price {
      font-family: var(--font-heading);
      font-weight: 900;
      font-size: 1.15rem;
      color: var(--clr-navy);
      text-decoration: line-through;
      text-decoration-color: var(--clr-coral);
    }
    .moz-value-actual {
      text-align: center;
      padding: 1.25rem 1.4rem;
      margin-top: 1rem;
      background: linear-gradient(135deg, var(--iek-stack-accent, var(--clr-teal)), color-mix(in srgb, var(--iek-stack-accent, var(--clr-teal)) 75%, #000 25%));
      color: #fff;
      border-radius: var(--r-lg);
      font-family: var(--font-heading);
      font-size: 1.2rem;
      font-weight: 900;
      box-shadow: var(--sh-md);
    }
    .moz-value-actual small { display: block; font-size: 0.8rem; font-weight: 600; margin-top: 0.3rem; opacity: 0.92; }

    /* ── SPLIT PAYMENT ── */
    .moz-split-pay {
      margin: 1rem 0 0;
      background: var(--clr-teal-light);
      border-left: 4px solid var(--clr-teal);
      border-radius: var(--r-md);
      padding: 1rem 1.25rem;
      text-align: left;
      font-size: 0.85rem;
      line-height: 1.55;
    }
    .moz-split-pay strong { color: var(--clr-teal-dark); }
    .moz-split-pay--coral {
      background: rgba(245,198,64,0.13);
      border-left-color: var(--clr-coral);
    }
    .moz-split-pay--coral strong { color: var(--clr-coral-dark); }

    /* ── INVEST vs RISK ── */
    .nyi-invest-risk {
      max-width: 920px;
      margin: 2rem auto 0;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.25rem;
    }
    @media (max-width: 720px) { .nyi-invest-risk { grid-template-columns: 1fr; } }
    .nyi-ir-card {
      background: #fff;
      border-radius: var(--r-lg);
      padding: 1.75rem 1.75rem 1.5rem;
      box-shadow: var(--sh-sm);
      position: relative;
      overflow: hidden;
    }
    .nyi-ir-card__eyebrow {
      font-size: 0.72rem; font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--clr-text-muted);
      margin-bottom: 0.5rem;
    }
    .nyi-ir-card__amount {
      font-family: var(--font-heading);
      font-size: 2.2rem;
      font-weight: 900;
      line-height: 1;
      margin-bottom: 0.65rem;
    }
    .nyi-ir-card p {
      margin: 0;
      font-size: 0.95rem;
      line-height: 1.6;
      color: var(--clr-text);
    }
    .nyi-ir-card--invest { border-top: 5px solid var(--clr-teal); }
    .nyi-ir-card--invest .nyi-ir-card__amount { color: var(--clr-teal-dark); }
    .nyi-ir-card--risk { border-top: 5px solid var(--clr-coral); }
    .nyi-ir-card--risk .nyi-ir-card__amount { color: var(--clr-coral-dark); }
    .nyi-ir-card--risk::before {
      content: '⚠';
      position: absolute;
      right: 1.25rem;
      top: 1rem;
      font-size: 1.4rem;
      opacity: 0.45;
    }

    /* ── GUARANTEE ── */
    .nyi-guarantee {
      max-width: 720px;
      margin: 2rem auto 0;
      background: linear-gradient(135deg, var(--clr-teal-light) 0%, rgba(245,198,64,0.12) 100%);
      border: 2px solid var(--clr-teal);
      border-radius: var(--r-lg);
      padding: 1.75rem 2rem;
      text-align: center;
    }
    .nyi-guarantee__icon { font-size: 2rem; margin-bottom: 0.5rem; display: block; }
    .nyi-guarantee h3 { color: var(--clr-teal-dark); font-size: 1.2rem; margin: 0 0 0.65rem; }
    .nyi-guarantee p { color: var(--clr-text); font-size: 0.98rem; line-height: 1.65; margin: 0; }
    .nyi-guarantee strong { color: var(--clr-teal-dark); }

    /* ── SOCIAL PROOF BAND ── */
    .moz-proof {
      display: grid;
      grid-template-columns: 1fr 2fr;
      gap: 2.5rem;
      align-items: center;
      max-width: 900px;
      margin: 0 auto;
      background: #fff;
      border-radius: var(--r-lg);
      padding: 2.5rem;
      box-shadow: var(--sh-md);
      border-left: 5px solid var(--clr-yellow);
    }
    .moz-proof__stat { text-align: center; }
    .moz-proof__stat strong {
      display: block;
      font-family: var(--font-heading);
      font-size: 3.5rem;
      font-weight: 900;
      color: var(--clr-teal-dark);
      line-height: 1;
      margin-bottom: 0.25rem;
    }
    .moz-proof__stat span { font-size: 0.95rem; color: var(--clr-text-mid); line-height: 1.5; }
    .moz-proof__quote blockquote {
      font-style: italic;
      color: var(--clr-text);
      border-left: 3px solid var(--clr-coral);
      padding-left: 1.25rem;
      margin: 0;
      font-size: 1.05rem;
      line-height: 1.6;
    }
    .moz-proof__quote cite {
      display: block;
      margin-top: 0.75rem;
      font-style: normal;
      font-size: 0.88rem;
      color: var(--clr-text-mid);
      font-weight: 600;
    }
    @media (max-width: 720px) {
      .moz-proof { grid-template-columns: 1fr; padding: 1.75rem; gap: 1.5rem; }
      .moz-proof__stat strong { font-size: 2.75rem; }
    }
    .moz-stats-bar {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 1.25rem 2.5rem;
      margin: 2.5rem auto 0;
      padding: 1.5rem 2rem;
      background: rgba(43,116,109,0.08);
      border-radius: var(--r-lg);
      max-width: 760px;
    }
    .moz-stat { text-align: center; font-size: 0.9rem; color: var(--clr-text); }
    .moz-stat strong {
      display: block;
      font-family: var(--font-heading);
      font-size: 1.3rem;
      font-weight: 900;
      color: var(--clr-navy);
    }

    /* ── FOUNDER ── */
    .moz-founder {
      display: flex;
      gap: 2.5rem;
      align-items: flex-start;
      max-width: 900px;
      margin: 0 auto;
      background: #fff;
      border-radius: var(--r-lg);
      padding: 2.5rem;
      box-shadow: var(--sh-md);
      border-left: 5px solid var(--clr-royal);
    }
    .moz-founder__photo {
      flex: 0 0 180px;
      border-radius: var(--r-lg);
      overflow: hidden;
      box-shadow: var(--sh-sm);
    }
    .moz-founder__photo img {
      width: 100%; height: auto; display: block;
      aspect-ratio: 1/1;
      object-fit: cover;
    }
    .moz-founder__body { flex: 1 1 0; }
    .moz-founder__body h3 { color: var(--clr-navy); margin: 0 0 0.25rem; font-size: 1.3rem; }
    .moz-founder__role { color: var(--clr-teal); font-weight: 600; font-size: 0.9rem; margin: 0 0 1rem; }
    .moz-founder__quote {
      font-style: italic;
      color: var(--clr-text-mid);
      border-left: 3px solid var(--clr-yellow);
      padding-left: 1rem;
      margin: 0 0 1.25rem;
      line-height: 1.6;
      font-size: 0.95rem;
    }
    .moz-founder__facts {
      list-style: none;
      padding: 0; margin: 0;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.5rem 1.5rem;
    }
    .moz-founder__facts li {
      font-size: 0.88rem;
      color: var(--clr-text);
      line-height: 1.5;
      padding-left: 1.25rem;
      position: relative;
    }
    .moz-founder__facts li::before { content: '✓'; position: absolute; left: 0; color: var(--clr-teal); font-weight: 700; }
    @media (max-width: 640px) {
      .moz-founder { flex-direction: column; padding: 1.75rem; gap: 1.5rem; }
      .moz-founder__photo { flex: none; width: 140px; margin: 0 auto; }
      .moz-founder__body { text-align: center; }
      .moz-founder__quote { border-left: none; padding-left: 0; border-top: 3px solid var(--clr-yellow); padding-top: 1rem; }
      .moz-founder__facts { grid-template-columns: 1fr; text-align: left; }
    }

    /* ── FAQ ── */
    .faq-categories {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.5rem;
      margin: 0 auto 2.5rem;
    }
    .faq-cat-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.55rem 1.2rem;
      border: 2px solid #e2e8f0;
      border-radius: var(--r-full);
      background: #fff;
      color: var(--clr-text-mid);
      font-weight: 700;
      font-size: 0.9rem;
      cursor: pointer;
      transition: all var(--t-fast);
    }
    .faq-cat-btn:hover { border-color: var(--clr-teal); color: var(--clr-teal); }
    .faq-cat-btn.active { background: var(--clr-teal); border-color: var(--clr-teal); color: #fff; }
    .faq-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(min(100%, 340px), 1fr));
      gap: 1.25rem;
      max-width: 900px;
      margin: 0 auto;
    }
    .faq-card {
      background: #fff;
      border: 1px solid #e8ecf1;
      border-radius: var(--r-lg);
      overflow: hidden;
      transition: box-shadow var(--t-mid), border-color var(--t-mid);
    }
    .faq-card:hover { border-color: var(--clr-teal-light); box-shadow: var(--sh-sm); }
    .faq-card summary {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 1.25rem 1.5rem;
      font-weight: 700;
      font-size: 1rem;
      color: var(--clr-navy);
      cursor: pointer;
      list-style: none;
      transition: color var(--t-fast);
    }
    .faq-card summary::-webkit-details-marker { display: none; }
    .faq-card summary .faq-icon {
      flex-shrink: 0;
      width: 36px; height: 36px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: var(--r-md);
      font-size: 1.1rem;
    }
    .faq-card summary .faq-toggle {
      margin-left: auto;
      flex-shrink: 0;
      width: 28px; height: 28px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: var(--r-full);
      background: var(--clr-bg);
      color: var(--clr-teal);
      font-size: 1.2rem;
      font-weight: 400;
      transition: transform var(--t-mid), background var(--t-fast);
    }
    .faq-card[open] summary .faq-toggle { transform: rotate(45deg); background: var(--clr-teal-light); }
    .faq-card summary:hover { color: var(--clr-teal); }
    .faq-card .faq-answer {
      padding: 0 1.5rem 1.5rem;
      color: var(--clr-text-mid);
      line-height: 1.7;
      font-size: 0.95rem;
      border-top: 1px solid #f0f3f6;
      margin: 0 1rem;
      padding-top: 1rem;
    }
    .faq-card[data-cat] { transition: opacity var(--t-mid), box-shadow var(--t-mid), border-color var(--t-mid); }
    .faq-card.faq-hidden { display: none; }
    .faq-icon--general { background: var(--clr-teal-light); color: var(--clr-teal-dark); }
    .faq-icon--program { background: #FEF3CD; color: #856404; }
    .faq-icon--practical { background: #E8F4FD; color: var(--clr-sky); }
    .faq-icon--price { background: #E6F9E0; color: var(--clr-green); }

    /* ── DUÁL FORM GRID (új a duál-offerhez) ── */
    .iek-form-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      max-width: 1080px;
      margin: 0 auto;
      align-items: stretch;
    }
    @media (max-width: 880px) {
      .iek-form-grid { grid-template-columns: 1fr; }
    }
    .iek-form-card {
      background: #fff;
      border-radius: var(--r-lg);
      padding: 1.75rem 1.75rem;
      box-shadow: var(--sh-md);
      position: relative;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      /* neutralize conflicting globals from .program-signup (style.src.css:3431) */
      max-width: none;
      margin: 0;
      text-align: left;
    }
    .iek-form-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 5px;
      background: var(--iek-form-accent, var(--clr-teal));
    }
    .iek-form-card--coral { --iek-form-accent: var(--clr-coral); }
    .iek-form-card--teal  { --iek-form-accent: var(--clr-teal); }
    .iek-form-card h3 { color: var(--clr-navy); margin: 0 0 0.4rem; font-size: 1.15rem; }
    .iek-form-card__sub { font-size: 0.88rem; color: var(--clr-text-mid); line-height: 1.55; margin: 0 0 1.1rem; }
    .iek-form-card__sub strong { color: var(--clr-navy); }
    .iek-form-card form { display: flex; flex-direction: column; gap: 0.65rem; }
    .iek-form-card input[type="text"],
    .iek-form-card input[type="email"],
    .iek-form-card input[type="tel"],
    .iek-form-card input[type="number"] {
      padding: 0.75rem 1rem;
      border: 1.5px solid #e2e8f0;
      border-radius: var(--r-md);
      font-size: 0.95rem;
      font-family: inherit;
      transition: border-color var(--t-fast);
    }
    .iek-form-card input:focus {
      outline: none;
      border-color: var(--iek-form-accent, var(--clr-teal));
    }
    .iek-form-card button[type="submit"] {
      margin-top: 0.5rem;
      background: var(--iek-form-accent, var(--clr-teal));
      color: #fff;
      border: none;
      padding: 1rem 1.5rem;  /* touch target ≥ 48px (responsive-design skill: WCAG min 44px) */
      min-height: 48px;
      border-radius: var(--r-md);
      font-size: 1rem;
      font-weight: 800;
      font-family: var(--font-heading);
      cursor: pointer;
      transition: transform var(--t-fast), box-shadow var(--t-fast);
      box-shadow: 0 4px 14px rgba(0,0,0,0.1);
    }
    .iek-form-card button[type="submit"]:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 22px rgba(0,0,0,0.16);
    }
    .iek-form-card .program-form-error { color: var(--clr-coral); font-size: 0.85rem; margin: 0.25rem 0 0; min-height: 1.1em; }
    .iek-form-card .program-signup-gdpr { font-size: 0.78rem; color: var(--clr-text-muted); margin: 0.75rem 0 0; }
    .iek-form-card .program-signup-gdpr a { color: var(--clr-teal); }
    .iek-form-card .program-signup-success { display: none; text-align: center; padding: 0.5rem 0; }
    .iek-form-card .program-signup-success.active { display: block; }
    .iek-form-card .program-signup-success .success-icon {
      width: 56px; height: 56px;
      background: var(--clr-teal);
      color: #fff;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.8rem;
      margin: 0 auto 0.75rem;
    }
    .iek-form-card .program-signup-success h4 { color: var(--clr-teal-dark); margin: 0 0 0.5rem; }
    .iek-form-card .program-signup-success p { color: var(--clr-text-mid); font-size: 0.92rem; line-height: 1.55; margin: 0; }
    .iek-form-callout {
      max-width: 720px;
      margin: 2rem auto 0;
      padding: 1.25rem 1.5rem;
      background: var(--clr-bg);
      border-radius: var(--r-md);
      text-align: center;
      font-size: 0.95rem;
      color: var(--clr-text-mid);
    }
    .iek-form-callout strong { color: var(--clr-navy); }
    .iek-form-callout a { color: var(--clr-teal); font-weight: 700; }

    /* ── CROSS-PROMO BRIDGE ── */
    .moz-online-bridge {
      max-width: 920px;
      margin: 2rem auto 0;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }
    @media (max-width: 760px) { .moz-online-bridge { grid-template-columns: 1fr; } }
    .moz-bridge-card {
      background: #fff;
      border-radius: var(--r-lg);
      padding: 2rem;
      box-shadow: var(--sh-md);
      display: flex;
      flex-direction: column;
    }
    .moz-bridge-card--offline { border-top: 5px solid var(--clr-purple); }
    .moz-bridge-card--online { border-top: 5px solid var(--clr-yellow); }
    .moz-bridge-card__eyebrow {
      font-size: 0.72rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--clr-coral);
      margin-bottom: 0.4rem;
    }
    .moz-bridge-card--online .moz-bridge-card__eyebrow { color: var(--clr-teal); }
    .moz-bridge-card h3 { color: var(--clr-navy); margin: 0 0 0.5rem; font-size: 1.2rem; }
    .moz-bridge-card p { color: var(--clr-text-mid); font-size: 0.95rem; line-height: 1.6; margin: 0 0 1.25rem; }
    .moz-bridge-card ul { list-style: none; padding: 0; margin: 0 0 1.25rem; }
    .moz-bridge-card ul li {
      padding: 0.3rem 0 0.3rem 1.5rem;
      position: relative;
      font-size: 0.9rem;
      color: var(--clr-text);
      line-height: 1.5;
    }
    .moz-bridge-card--offline ul li::before { content: '✓'; position: absolute; left: 0; color: var(--clr-purple); font-weight: 700; }
    .moz-bridge-card--online ul li::before { content: '→'; position: absolute; left: 0; color: var(--clr-teal); font-weight: 700; }
    .moz-bridge-card .btn { margin-top: auto; }

    /* ── ZF cross-promo bar ── */
    .zf-bar {
      display: flex;
      align-items: center;
      justify-content: center;
      flex-wrap: wrap;
      gap: 0.75rem 1.25rem;
      max-width: 920px;
      margin: 0 auto;
      padding: 0.85rem 1.25rem;
      background: #fafbfc;
      border: 1px solid rgba(43,116,109,0.12);
      border-radius: var(--r-full);
      font-size: 0.9rem;
      color: var(--clr-text-mid);
    }
    .zf-bar__icon { flex-shrink: 0; font-size: 1.1rem; line-height: 1; }
    .zf-bar__text { flex: 1 1 auto; min-width: 0; }
    .zf-bar__text strong { color: var(--clr-navy); font-weight: 700; }
    .zf-bar__link {
      flex-shrink: 0;
      color: var(--clr-teal-dark);
      font-weight: 700;
      text-decoration: none;
      font-size: 0.9rem;
      white-space: nowrap;
      transition: color var(--t-fast);
    }
    .zf-bar__link:hover, .zf-bar__link:focus { color: var(--clr-teal); text-decoration: underline; }
    @media (max-width: 640px) {
      .zf-bar { border-radius: var(--r-md); text-align: center; padding: 1rem; }
      .zf-bar__text { flex-basis: 100%; }
    }

    /* ── STICKY MOBILE CTA ── */
    .iek-sticky-cta { display: none; }
    @media (max-width: 640px) {
      .iek-sticky-cta {
        display: flex;
        position: fixed;
        bottom: 0; left: 0; right: 0;
        z-index: 50;
        background: rgba(255,255,255,0.97);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        border-top: 1px solid rgba(29,53,87,0.08);
        padding: 0.65rem 1rem calc(0.65rem + env(safe-area-inset-bottom));
        box-shadow: 0 -4px 20px rgba(29,53,87,0.08);
        gap: 0.5rem;
        opacity: 0;
        transform: translateY(110%);
        transition: opacity var(--t-mid), transform var(--t-mid);
        pointer-events: none;
      }
      .iek-sticky-cta.visible {
        opacity: 1;
        transform: translateY(0);
        pointer-events: auto;
      }
      .iek-sticky-cta .btn { flex: 1; justify-content: center; padding: 0.65rem 0.85rem; font-size: 0.85rem; }
      .iek-sticky-cta .btn-icon { flex: 0 0 44px; padding: 0.65rem 0; }
    }
    @media (prefers-reduced-motion: reduce) { .iek-sticky-cta { transition: opacity 0.1s ease; } }

    @media (max-width: 640px) {
      .moz-value-item { font-size: 0.85rem; }
      .moz-value-actual { font-size: 1.1rem; padding: 1.1rem; }
    }
