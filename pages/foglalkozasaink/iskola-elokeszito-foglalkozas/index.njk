            var lb = document.getElementById(id);
            if (lb) {
              lb.classList.add('is-open');
              document.body.classList.add('iek-lb-active');
            }
          }
          document.addEventListener('click', function(e) {
            var thumb = e.target.closest('.iek-gallery__item[href^="#iek-lb-"]');
            if (thumb) {
              e.preventDefault();
              e.stopImmediatePropagation();
              openById(thumb.getAttribute('href').slice(1));
              return;
            }
            var closeEl = e.target.closest('.iek-lightbox__close, .iek-lightbox__backdrop');
            if (closeEl) {
              e.preventDefault();
              e.stopImmediatePropagation();
              closeAll();
              return;
            }
            var navEl = e.target.closest('.iek-lightbox__nav a[href^="#iek-lb-"]');
            if (navEl) {
              e.preventDefault();
              e.stopImmediatePropagation();
              openById(navEl.getAttribute('href').slice(1));
              return;
            }
          }, true);
          document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' && document.body.classList.contains('iek-lb-active')) {
              closeAll();
            }
          });
          if (location.hash && location.hash.indexOf('#iek-lb-') === 0) {
            openById(location.hash.slice(1));
          }
        }

        /* ───── FAQ kategória-szűrő ───── */
        var faqBtns = document.querySelectorAll('.faq-cat-btn');
        var faqCards = document.querySelectorAll('.faq-card[data-cat]');
        if (faqBtns.length && faqCards.length) {
          faqBtns.forEach(function(btn) {
            btn.addEventListener('click', function() {
              var filter = btn.dataset.filter;
              faqBtns.forEach(function(b) {
                b.classList.toggle('active', b === btn);
                b.setAttribute('aria-selected', b === btn ? 'true' : 'false');
              });
              faqCards.forEach(function(card) {
                if (filter === 'all' || card.dataset.cat === filter) {
                  card.hidden = false;
                } else {
                  card.hidden = true;
                }
              });
            });
          });
        }

        /* ───── Preselect: CTA-gombról a form rádió-kiválasztása ───── */
        document.addEventListener('click', function(e) {
          var trigger = e.target.closest('a[data-preselect]');
          if (!trigger) return;
          var value = trigger.dataset.preselect;
          if (!value) return;
          /* Hagyjuk a normál anchor-scroll lefutni — utána állítsuk a radio-t */
          setTimeout(function() {
            var radio = document.querySelector('input[name="program_choice"][value="' + value + '"]');
            if (radio) radio.checked = true;
          }, 50);
        });
      })();
    </script>
