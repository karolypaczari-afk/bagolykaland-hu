        <div class="section-cta-actions fade-up stagger-2" style="margin-top:2rem;">
          <a href="#jelentkezes" class="btn btn-primary btn-lg">Lefoglalom az egyik helyet</a>
          <a href="tel:+36303649396" class="btn btn-outline-white">+36 30 364 9396</a>
        </div>
