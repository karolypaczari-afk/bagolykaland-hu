    <script>
    (function() {
      var btns = document.querySelectorAll('.faq-cat-btn');
      var cards = document.querySelectorAll('.faq-card[data-cat]');
      btns.forEach(function(btn) {
        btn.addEventListener('click', function() {
          btns.forEach(function(b) { b.classList.remove('active'); });
          btn.classList.add('active');
          var f = btn.getAttribute('data-filter');
          cards.forEach(function(c) {
            if (f === 'all' || c.getAttribute('data-cat') === f) {
              c.classList.remove('faq-hidden');
            } else {
              c.classList.add('faq-hidden');
            }
          });
        });
      });
    })();
    </script>
    <script>
    (function() {
      document.querySelectorAll('[data-select-turnus]').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var val = btn.getAttribute('data-select-turnus');
          var sel = document.querySelector('select[name="turnus"]');
          if (!sel || !val) return;
          for (var i = 0; i < sel.options.length; i++) {
            if (sel.options[i].value === val) {
              sel.selectedIndex = i;
              break;
            }
          }
        });
      });
    })();
    </script>
