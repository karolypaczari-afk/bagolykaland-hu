          <button class="camp-lightbox__nav camp-lightbox__prev" aria-label="Előző kép">&#8249;</button>
          <img class="camp-lightbox__img" id="campLightboxImg" src="" alt="" />
          <button class="camp-lightbox__nav camp-lightbox__next" aria-label="Következő kép">&#8250;</button>
          <div class="camp-lightbox__counter" id="campLightboxCounter"></div>
        </div>
