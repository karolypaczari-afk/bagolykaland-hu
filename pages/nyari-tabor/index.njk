---
layout: "base.njk"
title: "Kincskereső Élménytábor 2026 – Nyári tábor 5–8 éveseknek | BagolykaLand Debrecen"
description: "40+ fejlesztő tevékenység, mesés kalandok, max 12 fő/turnus. 9+ éve bevált nyári tábor Debrecenben 5–8 éves gyerekeknek. Július 14–18. és 21–25."
preloadHero: "/img/bagolykaland-kincskereso-tabor-hero.webp"
ogImage: "https://bagolykaland.hu/img/bagolykaland-kincskereso-tabor-hero.webp"
headStyles: |

    .camp-urgency {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--clr-coral);
      color: #fff;
      font-size: 0.85rem;
      font-weight: 700;
      padding: 0.5rem 1.25rem;
      border-radius: var(--r-full);
      margin-bottom: 1.25rem;
      animation: ctaPulse 2.5s ease-in-out infinite;
    }
    .camp-dates-bar {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      justify-content: center;
      margin: 2rem 0 0;
    }
    .camp-date-chip {
      background: rgba(255,255,255,0.2);
      backdrop-filter: blur(6px);
      border: 1px solid rgba(255,255,255,0.3);
      color: #fff;
      padding: 0.6rem 1.5rem;
      border-radius: var(--r-full);
      font-weight: 700;
      font-size: 0.95rem;
    }
    .story-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(min(100%, 280px), 1fr));
      gap: 1.5rem;
      margin-top: 2rem;
    }
    .story-card {
      background: #fff;
      border-radius: var(--r-md);
      padding: 1.5rem;
      box-shadow: var(--sh-sm);
      border-left: 4px solid var(--clr-yellow);
      transition: transform var(--t-mid), box-shadow var(--t-mid);
    }
    .story-card:hover {
      transform: translateY(-3px);
      box-shadow: var(--sh-md);
    }
    .story-card__day {
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      color: var(--clr-coral);
      letter-spacing: 0.05em;
      margin-bottom: 0.25rem;
    }
    .story-card h4 {
      color: var(--clr-navy);
      margin: 0 0 0.5rem;
      font-size: 1.05rem;
    }
    .story-card p {
      font-size: 0.9rem;
      color: var(--clr-text-mid);
      margin: 0;
      line-height: 1.6;
    }
    .camp-gallery {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(min(100%, 220px), 1fr));
      gap: 1rem;
      margin-top: 2rem;
    }
    .camp-gallery-item {
      border-radius: var(--r-md);
      overflow: hidden;
      box-shadow: var(--sh-sm);
      transition: transform var(--t-mid), box-shadow var(--t-mid);
      cursor: pointer;
      position: relative;
    }
    .camp-gallery-item::after {
      content: '';
      position: absolute;
      inset: 0;
      background: rgba(29,53,87,0);
      transition: background var(--t-mid);
      pointer-events: none;
    }
    .camp-gallery-item:hover::after {
      background: rgba(29,53,87,0.18);
    }
    .camp-gallery-item:hover {
      transform: translateY(-4px);
      box-shadow: var(--sh-md);
    }
    .camp-gallery-item img {
      width: 100%;
      height: 200px;
      object-fit: cover;
      display: block;
      transition: transform var(--t-mid);
    }
    .camp-gallery-item:hover img {
      transform: scale(1.06);
    }

    /* Lightbox */
    .camp-lightbox {
      position: fixed;
      inset: 0;
      z-index: 9999;
      background: rgba(0,0,0,0.92);
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.3s ease, visibility 0.3s ease;
      -webkit-backdrop-filter: blur(8px);
      backdrop-filter: blur(8px);
    }
    .camp-lightbox.is-open {
      opacity: 1;
      visibility: visible;
    }
    .camp-lightbox__img {
      max-width: min(90vw, 1100px);
      max-height: 85vh;
      object-fit: contain;
      border-radius: var(--r-md);
      box-shadow: 0 8px 60px rgba(0,0,0,0.6);
      transition: transform 0.3s ease, opacity 0.25s ease;
      transform: scale(0.92);
      opacity: 0;
      user-select: none;
      -webkit-user-drag: none;
    }
    .camp-lightbox.is-open .camp-lightbox__img {
      transform: scale(1);
      opacity: 1;
    }
    .camp-lightbox__close {
      position: absolute;
      top: 1rem;
      right: 1rem;
      width: 44px;
      height: 44px;
      background: rgba(255,255,255,0.15);
      border: none;
      border-radius: 50%;
      color: #fff;
      font-size: 1.5rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background var(--t-fast), transform var(--t-fast);
      z-index: 2;
    }
    .camp-lightbox__close:hover {
      background: rgba(255,255,255,0.3);
      transform: scale(1.1);
    }
    .camp-lightbox__nav {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      width: 48px;
      height: 48px;
      background: rgba(255,255,255,0.12);
      border: none;
      border-radius: 50%;
      color: #fff;
      font-size: 1.3rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background var(--t-fast), transform var(--t-fast);
      z-index: 2;
    }
    .camp-lightbox__nav:hover {
      background: rgba(255,255,255,0.3);
      transform: translateY(-50%) scale(1.1);
    }
    .camp-lightbox__prev { left: 1rem; }
    .camp-lightbox__next { right: 1rem; }
    .camp-lightbox__counter {
      position: absolute;
      bottom: 1.25rem;
      left: 50%;
      transform: translateX(-50%);
      color: rgba(255,255,255,0.7);
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 0.05em;
    }
    @media (max-width: 640px) {
      .camp-lightbox__nav {
        width: 40px;
        height: 40px;
        font-size: 1.1rem;
      }
      .camp-lightbox__prev { left: 0.5rem; }
      .camp-lightbox__next { right: 0.5rem; }
      .camp-lightbox__img {
        max-width: 96vw;
        max-height: 75vh;
        border-radius: var(--r-sm);
      }
    }
    .camp-team {
      display: flex;
      flex-wrap: wrap;
      gap: 2rem;
      align-items: center;
      margin-top: 2rem;
    }
    .camp-team-photo {
      flex: 0 0 200px;
      border-radius: var(--r-lg);
      overflow: hidden;
      box-shadow: var(--sh-md);
    }
    .camp-team-photo img {
      width: 100%;
      height: auto;
      display: block;
    }
    .camp-team-info {
      flex: 1 1 300px;
    }
    .session-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(min(100%, 320px), 1fr));
      gap: 2rem;
      margin-top: 2rem;
    }
    .session-card {
      background: #fff;
      border-radius: var(--r-lg);
      padding: 2.5rem 2rem;
      box-shadow: var(--sh-md);
      text-align: center;
      border-top: 5px solid var(--clr-yellow);
      transition: transform var(--t-mid), box-shadow var(--t-mid);
    }
    .session-card:hover {
      transform: translateY(-4px);
      box-shadow: var(--sh-lg);
    }
    .session-card__label {
      font-size: 0.8rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--clr-coral);
      margin-bottom: 0.5rem;
    }
    .session-card h3 {
      color: var(--clr-navy);
      font-size: 1.4rem;
      margin: 0 0 0.75rem;
    }
    .session-card__detail {
      font-size: 0.95rem;
      color: var(--clr-text-mid);
      line-height: 1.8;
      margin-bottom: 1.5rem;
    }
    .session-card__spots {
      display: inline-block;
      background: #FEF3CD;
      color: #856404;
      font-weight: 700;
      font-size: 0.85rem;
      padding: 0.4rem 1rem;
      border-radius: var(--r-full);
      margin-bottom: 1.5rem;
    }
    /* ── FAQ categories ── */
    .faq-categories {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.5rem;
      margin: 0 auto 2.5rem;
    }
    .faq-cat-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.55rem 1.2rem;
      border: 2px solid #e2e8f0;
      border-radius: var(--r-full);
      background: #fff;
      color: var(--clr-text-mid);
      font-weight: 700;
      font-size: 0.9rem;
      cursor: pointer;
      transition: all var(--t-fast);
    }
    .faq-cat-btn:hover {
      border-color: var(--clr-teal);
      color: var(--clr-teal);
    }
    .faq-cat-btn.active {
      background: var(--clr-teal);
      border-color: var(--clr-teal);
      color: #fff;
    }

    /* ── FAQ card grid ── */
    .faq-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(min(100%, 340px), 1fr));
      gap: 1.25rem;
      max-width: 900px;
      margin: 0 auto;
    }
    .faq-card {
      background: #fff;
      border: 1px solid #e8ecf1;
      border-radius: var(--r-lg);
      overflow: hidden;
      transition: box-shadow var(--t-mid), border-color var(--t-mid);
    }
    .faq-card:hover {
      border-color: var(--clr-teal-light);
      box-shadow: var(--sh-sm);
    }
    .faq-card summary {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 1.25rem 1.5rem;
      font-weight: 700;
      font-size: 1rem;
      color: var(--clr-navy);
      cursor: pointer;
      list-style: none;
      transition: color var(--t-fast);
    }
    .faq-card summary::-webkit-details-marker { display: none; }
    .faq-card summary .faq-icon {
      flex-shrink: 0;
      width: 36px;
      height: 36px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: var(--r-md);
      font-size: 1.1rem;
    }
    .faq-card summary .faq-toggle {
      margin-left: auto;
      flex-shrink: 0;
      width: 28px;
      height: 28px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: var(--r-full);
      background: var(--clr-bg);
      color: var(--clr-teal);
      font-size: 1.2rem;
      font-weight: 400;
      transition: transform var(--t-mid), background var(--t-fast);
    }
    .faq-card[open] summary .faq-toggle {
      transform: rotate(45deg);
      background: var(--clr-teal-light);
    }
    .faq-card summary:hover { color: var(--clr-teal); }
    .faq-card .faq-answer {
      padding: 0 1.5rem 1.5rem;
      color: var(--clr-text-mid);
      line-height: 1.7;
      font-size: 0.95rem;
      border-top: 1px solid #f0f3f6;
      margin: 0 1rem;
      padding-top: 1rem;
    }
    .faq-card[data-cat] {
      transition: opacity var(--t-mid), box-shadow var(--t-mid), border-color var(--t-mid);
    }
    .faq-card.faq-hidden {
      display: none;
    }
    /* Category icon backgrounds */
    .faq-icon--general { background: var(--clr-teal-light); color: var(--clr-teal-dark); }
    .faq-icon--program { background: #FEF3CD; color: #856404; }
    .faq-icon--practical { background: #E8F4FD; color: var(--clr-sky); }
    .faq-icon--price { background: #E6F9E0; color: var(--clr-green); }
    .dev-benefits {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(min(100%, 240px), 1fr));
      gap: 1.25rem;
      margin-top: 2rem;
    }
    .dev-benefit {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
      padding: 1rem;
      background: rgba(245,198,64,0.08);
      border-radius: var(--r-md);
    }
    .dev-benefit__icon {
      font-size: 1.5rem;
      flex-shrink: 0;
    }
    .dev-benefit__text {
      font-size: 0.95rem;
      color: var(--clr-text);
      line-height: 1.5;
    }
    .dev-benefit__text strong {
      display: block;
      color: var(--clr-navy);
      margin-bottom: 0.15rem;
    }
    /* Founder card */
    .camp-founder {
      display: flex;
      gap: 2.5rem;
      align-items: flex-start;
      max-width: 900px;
      margin: 0 auto;
      background: #fff;
      border-radius: var(--r-lg);
      padding: 2.5rem;
      box-shadow: var(--sh-md);
      border-left: 5px solid var(--clr-yellow);
    }
    .camp-founder__photo {
      flex: 0 0 180px;
      border-radius: var(--r-lg);
      overflow: hidden;
      box-shadow: var(--sh-sm);
    }
    .camp-founder__photo img {
      width: 100%;
      height: auto;
      display: block;
      aspect-ratio: 1/1;
      object-fit: cover;
    }
    .camp-founder__body {
      flex: 1 1 0;
    }
    .camp-founder__body h3 {
      color: var(--clr-navy);
      margin: 0 0 0.25rem;
      font-size: 1.3rem;
    }
    .camp-founder__role {
      color: var(--clr-teal);
      font-weight: 600;
      font-size: 0.9rem;
      margin: 0 0 1rem;
    }
    .camp-founder__quote {
      font-style: italic;
      color: var(--clr-text-mid);
      border-left: 3px solid var(--clr-yellow);
      padding-left: 1rem;
      margin: 0 0 1.25rem;
      line-height: 1.6;
      font-size: 0.95rem;
    }
    .camp-founder__facts {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.5rem 1.5rem;
    }
    .camp-founder__facts li {
      font-size: 0.88rem;
      color: var(--clr-text);
      line-height: 1.5;
      padding-left: 1.25rem;
      position: relative;
    }
    .camp-founder__facts li::before {
      content: '✓';
      position: absolute;
      left: 0;
      color: var(--clr-teal);
      font-weight: 700;
    }
    /* Team grid */
    .camp-team-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(min(100%, 340px), 1fr));
      gap: 2rem;
      margin-top: 2.5rem;
      max-width: 900px;
      margin-left: auto;
      margin-right: auto;
    }
    .camp-team-member {
      background: #fff;
      border-radius: var(--r-md);
      overflow: hidden;
      box-shadow: var(--sh-sm);
      transition: transform var(--t-mid), box-shadow var(--t-mid);
    }
    .camp-team-member:hover {
      transform: translateY(-3px);
      box-shadow: var(--sh-md);
    }
    .camp-team-member img {
      width: 100%;
      height: 220px;
      object-fit: cover;
      display: block;
    }
    .camp-team-member__body {
      padding: 1.25rem 1.5rem;
    }
    .camp-team-member__body h4 {
      color: var(--clr-navy);
      margin: 0 0 0.5rem;
      font-size: 1.05rem;
    }
    .camp-team-member__body p {
      font-size: 0.9rem;
      color: var(--clr-text-mid);
      line-height: 1.6;
      margin: 0;
    }

    @media (max-width: 640px) {
      .camp-founder {
        flex-direction: column;
        padding: 1.5rem;
        gap: 1.5rem;
      }
      .camp-founder__photo {
        flex: none;
        width: 120px;
        margin: 0 auto;
      }
      .camp-founder__body {
        text-align: center;
      }
      .camp-founder__quote {
        border-left: none;
        padding-left: 0;
        border-top: 3px solid var(--clr-yellow);
        padding-top: 1rem;
      }
      .camp-founder__facts {
        grid-template-columns: 1fr;
        text-align: left;
      }
      .camp-gallery {
        grid-template-columns: repeat(2, 1fr);
        gap: 0.75rem;
      }
      .camp-gallery-item img {
        height: 150px;
      }
      .session-card {
        padding: 2rem 1.5rem;
      }
      .story-grid {
        gap: 1rem;
      }
      .camp-compare-grid {
        grid-template-columns: 1fr;
      }
      .camp-value-item {
        font-size: 0.88rem;
      }
      .camp-value-actual {
        font-size: 1.15rem;
        padding: 1.25rem;
      }
    }

    /* ── Pain points ── */
    .camp-pain-list {
      list-style: none;
      padding: 0;
      margin: 2rem auto 0;
      max-width: 640px;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .camp-pain-list li {
      padding-left: 2rem;
      position: relative;
      font-size: 1rem;
      color: var(--clr-text);
      line-height: 1.7;
    }
    .camp-pain-list li::before {
      content: '✗';
      position: absolute;
      left: 0;
      top: 0;
      color: var(--clr-coral);
      font-weight: 800;
      font-size: 1.1rem;
    }
    .camp-pain-transition {
      max-width: 640px;
      margin: 2.5rem auto 0;
      text-align: center;
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--clr-teal-dark);
      line-height: 1.6;
    }

    /* ── Story card skill tags ── */
    .story-card__skill {
      display: inline-block;
      font-size: 0.75rem;
      color: var(--clr-teal);
      font-weight: 700;
      margin-top: 0.5rem;
      letter-spacing: 0.02em;
    }

    /* ── 3-column compare ── */
    .camp-compare-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
      margin-top: 2rem;
    }
    @media (max-width: 900px) {
      .camp-compare-grid { grid-template-columns: 1fr; }
    }
    .camp-compare-grid .comparison-card {
      display: flex;
      flex-direction: column;
    }
    .camp-compare-grid .comparison-card h3 {
      min-height: 2.5rem;
    }

    /* ── Value stack ── */
    .camp-value-stack {
      max-width: 600px;
      margin: 2.5rem auto 0;
      background: #fff;
      border-radius: var(--r-lg);
      padding: 2rem 2.5rem;
      box-shadow: var(--sh-md);
    }
    .camp-value-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.75rem 0;
      border-bottom: 1px dashed rgba(29,53,87,0.12);
    }
    .camp-value-label {
      font-size: 0.95rem;
      color: var(--clr-text);
      flex: 1;
      padding-right: 1rem;
    }
    .camp-value-price {
      font-size: 0.9rem;
      color: var(--clr-text-muted);
      font-weight: 600;
      white-space: nowrap;
    }
    .camp-value-total {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1.25rem 0 0.75rem;
      border-top: 2px solid var(--clr-navy);
      margin-top: 0.25rem;
    }
    .camp-value-total-label {
      font-weight: 800;
      font-size: 1.05rem;
      color: var(--clr-navy);
    }
    .camp-value-total-price {
      font-family: var(--font-heading);
      font-weight: 900;
      font-size: 1.2rem;
      color: var(--clr-navy);
      text-decoration: line-through;
      text-decoration-color: var(--clr-coral);
    }
    .camp-value-actual {
      text-align: center;
      padding: 1.5rem 2rem;
      margin-top: 1.5rem;
      background: linear-gradient(135deg, var(--clr-coral), #c4613f);
      color: #fff;
      border-radius: var(--r-lg);
      font-family: var(--font-heading);
      font-size: 1.5rem;
      font-weight: 900;
      box-shadow: var(--sh-color-coral);
    }
    .camp-value-actual small {
      display: block;
      font-size: 0.85rem;
      font-weight: 600;
      margin-top: 0.35rem;
      opacity: 0.9;
    }
    .camp-value-sibling {
      text-align: center;
      margin-top: 1rem;
      font-size: 0.95rem;
      color: var(--clr-teal-dark);
      font-weight: 700;
    }

    /* ── Guarantee card ── */
    .camp-guarantee {
      max-width: 700px;
      margin: 0 auto;
      background: linear-gradient(135deg, var(--clr-teal-light) 0%, rgba(43,116,109,0.04) 100%);
      border-left: 5px solid var(--clr-teal);
      border-radius: var(--r-lg);
      padding: 2.5rem;
      text-align: center;
    }
    .camp-guarantee h3 {
      color: var(--clr-teal-dark);
      margin: 0 0 0.75rem;
      font-size: 1.25rem;
    }
    .camp-guarantee p {
      color: var(--clr-text);
      line-height: 1.7;
      margin: 0 0 0.75rem;
      font-size: 0.95rem;
    }
    .camp-guarantee small {
      color: var(--clr-text-muted);
      font-size: 0.85rem;
      font-style: italic;
    }

    /* ── Session card price ── */
    .session-card__price {
      font-family: var(--font-heading);
      font-size: 1.6rem;
      font-weight: 900;
      color: var(--clr-coral);
      margin-bottom: 0.25rem;
    }
    .session-card__price-note {
      font-size: 0.82rem;
      color: var(--clr-text-muted);
      margin-bottom: 1rem;
    }

    /* ── Stats bar ── */
    .camp-stats-bar {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 1.5rem 2.5rem;
      margin-top: 2.5rem;
      padding: 1.5rem 2rem;
      background: rgba(245,198,64,0.1);
