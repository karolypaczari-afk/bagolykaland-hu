      font-weight: 800;
      color: var(--clr-coral-dark);
      text-align: center;
      margin: 0 0 1.25rem;
    }
    .nyi-stakes__list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(min(100%, 280px), 1fr));
      gap: 0.85rem 1.25rem;
    }
    .nyi-stakes__list li {
