    .moz-story-card__skill {
      display: inline-block;
      font-size: 0.75rem;
      color: var(--clr-teal);
      font-weight: 700;
      margin-top: 0.75rem;
      letter-spacing: 0.02em;
    }

    /* ── 3-COL COMPARISON ENHANCED ── */
    .nyi-compare-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
      max-width: 1080px;
      margin: 2rem auto 0;
      align-items: stretch;
    }
    @media (max-width: 900px) { .nyi-compare-grid { grid-template-columns: 1fr; } }
    .nyi-compare-card {
      background: #fff;
      border: 2px solid var(--clr-border);
      border-radius: var(--r-lg);
      padding: 1.75rem 1.5rem;
      display: flex;
      flex-direction: column;
      transition: transform var(--t-mid), box-shadow var(--t-mid), border-color var(--t-mid);
    }
    .nyi-compare-card:hover { border-color: var(--clr-teal-light); box-shadow: var(--sh-sm); }
    .nyi-compare-card h3 { color: var(--clr-navy); font-size: 1.05rem; margin: 0 0 0.35rem; }
    .nyi-compare-card__price {
      font-family: var(--font-heading);
      font-weight: 900;
      font-size: 1.5rem;
      color: var(--clr-coral);
      margin: 0.35rem 0 0.75rem;
    }
    .nyi-compare-card__meta {
      font-size: 0.85rem;
      color: var(--clr-text-muted);
      line-height: 1.5;
      margin-bottom: 1rem;
    }
    .nyi-compare-card ul {
      list-style: none;
      padding: 0; margin: 0 0 1rem;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    .nyi-compare-card ul li {
      padding-left: 1.5rem;
      position: relative;
      font-size: 0.9rem;
      color: var(--clr-text);
      line-height: 1.5;
    }
    .nyi-compare-card ul li::before {
      content: '•';
      position: absolute; left: 0;
      color: var(--clr-text-muted);
      font-weight: 700;
    }
    .nyi-compare-card--featured {
      order: 0;
      border-color: var(--clr-coral);
      box-shadow: var(--sh-md);
      transform: translateY(-12px);
      position: relative;
      background: linear-gradient(180deg, #fff 0%, rgba(245,198,64,0.04) 100%);
      animation: nyiCompareGlow 2.4s ease-in-out infinite alternate;
    }
    .nyi-compare-card--featured h3 { color: var(--clr-coral-dark); }
    .nyi-compare-card--featured ul li::before { content: '✓'; color: var(--clr-teal); }
    .nyi-compare-card--featured .nyi-compare-card__pin {
      position: absolute;
      top: -14px;
      left: 50%;
      transform: translateX(-50%);
      background: var(--clr-coral);
      color: #fff;
      font-size: 0.72rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 0.3rem 0.85rem;
      border-radius: var(--r-full);
      box-shadow: var(--sh-color-coral);
      white-space: nowrap;
    }
    @keyframes nyiCompareGlow {
      from { box-shadow: var(--sh-md), 0 0 0 0 rgba(179,84,49,0.18); }
      to   { box-shadow: var(--sh-lg), 0 0 24px 4px rgba(179,84,49,0.22); }
    }
    .nyi-compare-card--risk { background: rgba(179,84,49,0.04); }
    .nyi-compare-card--risk h3 { color: var(--clr-coral-dark); }
    .nyi-compare-card--risk ul li::before { content: '✗'; color: var(--clr-coral); }
    @media (max-width: 900px) {
      .nyi-compare-card--featured { order: -1; transform: none; }
    }
    @media (prefers-reduced-motion: reduce) {
      .nyi-compare-card--featured { animation: none; }
    }

