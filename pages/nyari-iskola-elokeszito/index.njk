      color: var(--clr-teal-dark);
      line-height: 1.6;
    }

    /* ── STAKES / RISK FRAMING (új komponens — Hormozi inverse value) ── */
    .nyi-stakes {
      max-width: 760px;
      margin: 2rem auto 0;
      background: linear-gradient(135deg, rgba(179,84,49,0.06) 0%, rgba(245,198,64,0.05) 100%);
