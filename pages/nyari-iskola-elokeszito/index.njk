      position: relative;
      font-size: 0.95rem;
      color: var(--clr-text);
      line-height: 1.55;
    }
    .nyi-stakes__list li::before {
      content: '⚠';
      position: absolute;
      left: 0; top: 0;
      color: var(--clr-coral);
      font-weight: 800;
    }

    /* ── STORY (PHASE) CARDS ── */
    .moz-story-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(min(100%, 260px), 1fr));
      gap: 1.5rem;
      margin-top: 2rem;
