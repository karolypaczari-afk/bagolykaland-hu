      color: var(--clr-teal-dark);
      line-height: 1;
      margin-bottom: 0.25rem;
    }
    .moz-proof__stat span { font-size: 0.95rem; color: var(--clr-text-mid); line-height: 1.5; }
    .moz-proof__quote blockquote {
      font-style: italic;
      color: var(--clr-text);
      border-left: 3px solid var(--clr-coral);
      padding-left: 1.25rem;
      margin: 0;
      font-size: 1.05rem;
      line-height: 1.6;
    }
    .moz-proof__quote cite {
      display: block;
      margin-top: 0.75rem;
      font-style: normal;
      font-size: 0.88rem;
      color: var(--clr-text-mid);
      font-weight: 600;
    }
    @media (max-width: 720px) {
      .moz-proof { grid-template-columns: 1fr; padding: 1.75rem; gap: 1.5rem; }
      .moz-proof__stat strong { font-size: 2.75rem; }
    }
    .moz-stats-bar {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 1.25rem 2.5rem;
      margin: 2.5rem auto 0;
      padding: 1.5rem 2rem;
      background: rgba(43,116,109,0.08);
      border-radius: var(--r-lg);
      max-width: 760px;
    }
    .moz-stat { text-align: center; font-size: 0.9rem; color: var(--clr-text); }
    .moz-stat strong {
      display: block;
      font-family: var(--font-heading);
      font-size: 1.3rem;
      font-weight: 900;
      color: var(--clr-navy);
    }

    /* ── FOUNDER CARD ── */
    .moz-founder {
      display: flex;
      gap: 2.5rem;
      align-items: flex-start;
      max-width: 900px;
      margin: 0 auto;
      background: #fff;
      border-radius: var(--r-lg);
      padding: 2.5rem;
      box-shadow: var(--sh-md);
      border-left: 5px solid var(--clr-royal);
    }
    .moz-founder__photo {
      flex: 0 0 180px;
      border-radius: var(--r-lg);
      overflow: hidden;
      box-shadow: var(--sh-sm);
    }
    .moz-founder__photo img {
      width: 100%; height: auto; display: block;
      aspect-ratio: 1/1;
      object-fit: cover;
    }
    .moz-founder__body { flex: 1 1 0; }
    .moz-founder__body h3 { color: var(--clr-navy); margin: 0 0 0.25rem; font-size: 1.3rem; }
    .moz-founder__role { color: var(--clr-teal); font-weight: 600; font-size: 0.9rem; margin: 0 0 1rem; }
    .moz-founder__quote {
      font-style: italic;
      color: var(--clr-text-mid);
      border-left: 3px solid var(--clr-yellow);
      padding-left: 1rem;
      margin: 0 0 1.25rem;
      line-height: 1.6;
      font-size: 0.95rem;
    }
    .moz-founder__facts {
      list-style: none;
      padding: 0; margin: 0;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.5rem 1.5rem;
    }
    .moz-founder__facts li {
      font-size: 0.88rem;
      color: var(--clr-text);
      line-height: 1.5;
      padding-left: 1.25rem;
      position: relative;
    }
    .moz-founder__facts li::before {
      content: '✓'; position: absolute; left: 0;
      color: var(--clr-teal); font-weight: 700;
    }
    @media (max-width: 640px) {
      .moz-founder { flex-direction: column; padding: 1.75rem; gap: 1.5rem; }
      .moz-founder__photo { flex: none; width: 140px; margin: 0 auto; }
      .moz-founder__body { text-align: center; }
      .moz-founder__quote {
        border-left: none;
        padding-left: 0;
        border-top: 3px solid var(--clr-yellow);
        padding-top: 1rem;
      }
      .moz-founder__facts { grid-template-columns: 1fr; text-align: left; }
    }

    /* ── FAQ ── */
    .faq-categories {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.5rem;
      margin: 0 auto 2.5rem;
    }
    .faq-cat-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.55rem 1.2rem;
      border: 2px solid #e2e8f0;
      border-radius: var(--r-full);
      background: #fff;
      color: var(--clr-text-mid);
      font-weight: 700;
      font-size: 0.9rem;
      cursor: pointer;
      transition: all var(--t-fast);
    }
    .faq-cat-btn:hover { border-color: var(--clr-teal); color: var(--clr-teal); }
    .faq-cat-btn.active { background: var(--clr-teal); border-color: var(--clr-teal); color: #fff; }
    .faq-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(min(100%, 340px), 1fr));
      gap: 1.25rem;
      max-width: 900px;
      margin: 0 auto;
    }
    .faq-card {
      background: #fff;
      border: 1px solid #e8ecf1;
      border-radius: var(--r-lg);
      overflow: hidden;
      transition: box-shadow var(--t-mid), border-color var(--t-mid);
    }
    .faq-card:hover { border-color: var(--clr-teal-light); box-shadow: var(--sh-sm); }
    .faq-card summary {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 1.25rem 1.5rem;
      font-weight: 700;
      font-size: 1rem;
      color: var(--clr-navy);
      cursor: pointer;
      list-style: none;
      transition: color var(--t-fast);
    }
    .faq-card summary::-webkit-details-marker { display: none; }
    .faq-card summary .faq-icon {
      flex-shrink: 0;
      width: 36px; height: 36px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: var(--r-md);
      font-size: 1.1rem;
    }
    .faq-card summary .faq-toggle {
      margin-left: auto;
      flex-shrink: 0;
      width: 28px; height: 28px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: var(--r-full);
      background: var(--clr-bg);
      color: var(--clr-teal);
      font-size: 1.2rem;
      font-weight: 400;
      transition: transform var(--t-mid), background var(--t-fast);
    }
    .faq-card[open] summary .faq-toggle { transform: rotate(45deg); background: var(--clr-teal-light); }
    .faq-card summary:hover { color: var(--clr-teal); }
    .faq-card .faq-answer {
      padding: 0 1.5rem 1.5rem;
      color: var(--clr-text-mid);
      line-height: 1.7;
      font-size: 0.95rem;
      border-top: 1px solid #f0f3f6;
      margin: 0 1rem;
      padding-top: 1rem;
    }
    .faq-card[data-cat] { transition: opacity var(--t-mid), box-shadow var(--t-mid), border-color var(--t-mid); }
    .faq-card.faq-hidden { display: none; }
    .faq-icon--general { background: var(--clr-teal-light); color: var(--clr-teal-dark); }
    .faq-icon--program { background: #FEF3CD; color: #856404; }
    .faq-icon--practical { background: #E8F4FD; color: var(--clr-sky); }
    .faq-icon--price { background: #E6F9E0; color: var(--clr-green); }

    /* ── CROSS-PROMO BRIDGE ── */
    .moz-online-bridge {
      max-width: 920px;
      margin: 2rem auto 0;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }
    @media (max-width: 760px) {
      .moz-online-bridge { grid-template-columns: 1fr; }
    }
    .moz-bridge-card {
      background: #fff;
      border-radius: var(--r-lg);
      padding: 2rem;
      box-shadow: var(--sh-md);
      display: flex;
      flex-direction: column;
    }
    .moz-bridge-card--offline { border-top: 5px solid var(--clr-teal); }
    .moz-bridge-card--online { border-top: 5px solid var(--clr-yellow); }
    .moz-bridge-card__eyebrow {
      font-size: 0.72rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--clr-coral);
      margin-bottom: 0.4rem;
    }
    .moz-bridge-card--online .moz-bridge-card__eyebrow { color: var(--clr-teal); }
    .moz-bridge-card h3 {
      color: var(--clr-navy);
      margin: 0 0 0.5rem;
      font-size: 1.2rem;
    }
    .moz-bridge-card p {
      color: var(--clr-text-mid);
      font-size: 0.95rem;
      line-height: 1.6;
      margin: 0 0 1.25rem;
    }
    .moz-bridge-card ul {
      list-style: none;
      padding: 0;
      margin: 0 0 1.25rem;
    }
    .moz-bridge-card ul li {
      padding: 0.3rem 0 0.3rem 1.5rem;
      position: relative;
      font-size: 0.9rem;
      color: var(--clr-text);
      line-height: 1.5;
    }
    .moz-bridge-card--offline ul li::before {
      content: '✓';
      position: absolute;
      left: 0;
      color: var(--clr-teal);
      font-weight: 700;
    }
    .moz-bridge-card--online ul li::before {
      content: '→';
      position: absolute;
      left: 0;
      color: var(--clr-teal);
      font-weight: 700;
    }
    .moz-bridge-card .btn { margin-top: auto; }

    /* ── ZF cross-promo bar ── */
    .zf-bar {
      display: flex;
      align-items: center;
      justify-content: center;
      flex-wrap: wrap;
      gap: 0.75rem 1.25rem;
      max-width: 920px;
      margin: 0 auto;
      padding: 0.85rem 1.25rem;
      background: #fafbfc;
      border: 1px solid rgba(43,116,109,0.12);
      border-radius: var(--r-full);
      font-size: 0.9rem;
      color: var(--clr-text-mid);
    }
    .zf-bar__icon { flex-shrink: 0; font-size: 1.1rem; line-height: 1; }
    .zf-bar__text { flex: 1 1 auto; min-width: 0; }
    .zf-bar__text strong { color: var(--clr-navy); font-weight: 700; }
    .zf-bar__link {
      flex-shrink: 0;
      color: var(--clr-teal-dark);
      font-weight: 700;
      text-decoration: none;
      font-size: 0.9rem;
      white-space: nowrap;
      transition: color var(--t-fast);
    }
    .zf-bar__link:hover, .zf-bar__link:focus { color: var(--clr-teal); text-decoration: underline; }
    @media (max-width: 640px) {
      .zf-bar { border-radius: var(--r-md); text-align: center; padding: 1rem; }
      .zf-bar__text { flex-basis: 100%; }
    }

    /* ── STICKY MOBILE CTA ── */
    .nyi-sticky-cta {
      display: none;
    }
    @media (max-width: 640px) {
      .nyi-sticky-cta {
        display: flex;
        position: fixed;
        bottom: 0; left: 0; right: 0;
        z-index: 50;
        background: rgba(255,255,255,0.97);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        border-top: 1px solid rgba(29,53,87,0.08);
        padding: 0.65rem 1rem calc(0.65rem + env(safe-area-inset-bottom));
        box-shadow: 0 -4px 20px rgba(29,53,87,0.08);
        gap: 0.5rem;
        opacity: 0;
        transform: translateY(110%);
        transition: opacity var(--t-mid), transform var(--t-mid);
        pointer-events: none;
      }
      .nyi-sticky-cta.visible {
        opacity: 1;
        transform: translateY(0);
        pointer-events: auto;
      }
      .nyi-sticky-cta .btn { flex: 1; justify-content: center; padding: 0.65rem 1rem; font-size: 0.9rem; }
      .nyi-sticky-cta .btn-icon { flex: 0 0 44px; padding: 0.65rem 0; }
    }
    @media (prefers-reduced-motion: reduce) {
      .nyi-sticky-cta { transition: opacity 0.1s ease; }
    }

    @media (max-width: 640px) {
      .moz-value-item { font-size: 0.88rem; }
      .moz-value-actual { font-size: 1.15rem; padding: 1.25rem; }
      .moz-story-grid { gap: 1rem; }
    }
