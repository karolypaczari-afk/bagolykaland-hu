    {# ── FAQ FILTER + STICKY CTA + COUNT-UP JS ── #}
    <script>
    (function() {
      // ── FAQ category filter ──
      var btns = document.querySelectorAll('.faq-cat-btn');
      var cards = document.querySelectorAll('.faq-card[data-cat]');
      btns.forEach(function(btn) {
        btn.addEventListener('click', function() {
          btns.forEach(function(b) { b.classList.remove('active'); });
          btn.classList.add('active');
          var f = btn.getAttribute('data-filter');
          cards.forEach(function(c) {
            if (f === 'all' || c.getAttribute('data-cat') === f) {
              c.classList.remove('faq-hidden');
            } else {
              c.classList.add('faq-hidden');
            }
          });
        });
      });

      // ── Sticky mobile CTA ──
      var stickyEl = document.getElementById('nyi-sticky-cta');
      if (stickyEl) {
        var lastShown = false;
        var threshold = 800;
        var formAnchor = document.getElementById('jelentkezes');
        function updateSticky() {
          var shouldShow = window.scrollY > threshold;
          if (formAnchor) {
            var rect = formAnchor.getBoundingClientRect();
            if (rect.top < window.innerHeight && rect.bottom > 0) shouldShow = false;
          }
          if (shouldShow !== lastShown) {
            stickyEl.classList.toggle('visible', shouldShow);
            stickyEl.setAttribute('aria-hidden', shouldShow ? 'false' : 'true');
            lastShown = shouldShow;
          }
        }
        window.addEventListener('scroll', updateSticky, { passive: true });
        updateSticky();
      }

      // ── Value stack count-up animation ──
      var prm = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      var totalEl = document.querySelector('.moz-value-total-price');
      if (totalEl && !prm && 'IntersectionObserver' in window) {
        var animated = false;
        var io = new IntersectionObserver(function(entries) {
          entries.forEach(function(e) {
            if (e.isIntersecting && !animated) {
              animated = true;
              var target = 370000;
              var start = performance.now();
              var dur = 1100;
              function step(now) {
                var p = Math.min(1, (now - start) / dur);
                var eased = 1 - Math.pow(1 - p, 3);
                var val = Math.floor(target * eased);
                totalEl.textContent = val.toLocaleString('hu-HU').replace(/\s/g, '.') + ' Ft';
                if (p < 1) requestAnimationFrame(step);
                else totalEl.textContent = '370.000 Ft';
              }
              requestAnimationFrame(step);
              io.disconnect();
            }
          });
        }, { threshold: 0.45 });
        io.observe(totalEl);
      }
    })();
    </script>
