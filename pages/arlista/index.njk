headStyles: |
  
      .pricing-table {
        max-width: 820px;
        margin: 2rem auto 0;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 4px 24px rgba(0,0,0,0.08);
      }
      .pricing-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.25rem 1.75rem;
        border-bottom: 1px solid #e8f0ec;
        background: #fff;
        gap: 1rem;
      }
      .pricing-row:last-child {
        border-bottom: none;
      }
      .pricing-row:nth-child(odd) {
        background: #f8fdf9;
      }
      .pricing-row__name {
        font-weight: 600;
        color: #1D3557;
        font-size: 1rem;
      }
      .pricing-row__name-link {
        color: inherit;
        text-decoration: none;
        display: inline-flex;
        align-items: baseline;
        gap: .4rem;
        transition: color .2s ease;
      }
      .pricing-row__name-link::after {
        content: "→";
        font-weight: 700;
        color: var(--clr-teal);
        opacity: .55;
        transition: transform .2s ease, opacity .2s ease;
      }
      .pricing-row__name-link:hover,
      .pricing-row__name-link:focus-visible {
        color: var(--clr-teal);
        text-decoration: underline;
        text-decoration-thickness: 2px;
        text-underline-offset: 3px;
      }
      .pricing-row__name-link:hover::after,
      .pricing-row__name-link:focus-visible::after {
        transform: translateX(4px);
        opacity: 1;
      }
        .pricing-row__detail {
          font-size: .875rem;
          color: var(--clr-text-muted);
          margin-top: .2rem;
        }
        .pricing-row__price {
          font-family: 'Nunito', sans-serif;
          font-weight: 800;
          font-size: 1.2rem;
          color: var(--clr-coral);
          white-space: nowrap;
        }
        .pricing-row__unit {
          font-size: .8rem;
          font-weight: 400;
          color: var(--clr-text-muted);
          display: block;
          text-align: right;
        }
      .pricing-table__header {
        background: #1D3557;
        color: #fff;
        padding: 1rem 1.75rem;
        font-family: 'Nunito', sans-serif;
        font-weight: 800;
        font-size: 1.1rem;
        letter-spacing: .03em;
      }
      @media (max-width: 640px) {
        .pricing-row {
          flex-direction: column;
          align-items: flex-start;
          gap: .5rem;
        }
        .pricing-row__price {
          align-self: flex-end;
        }
      }
